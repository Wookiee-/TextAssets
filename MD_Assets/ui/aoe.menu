		//----------------------------------------------------------------------------------------------
		//
		//   NEW GAME MENU specific stuff
		//
		//----------------------------------------------------------------------------------------------		

		//Arrows In Right Corner

		itemDef 
		{
			name				forward_glow
			group				none
			style				WINDOW_STYLE_SHADER
			rect				0 0 0 0
			background			"gfx/menus/forward_icon_glow"
			forecolor			1 1 1 1
			visible				0
			decoration
		}

		itemDef 
		{
			name				back_glow
			group				none
			style				WINDOW_STYLE_SHADER
			rect				0 0 0 0
			background			"gfx/menus/back_icon_glow"
			forecolor			1 1 1 1
			visible				0
			decoration
		}

		itemDef 
		{
			name				benselect
			group				none
			style				WINDOW_STYLE_SHADER
			type				ITEM_TYPE_BUTTON
			rect				25 169 150 150
			background			"gfx/menus/charactericons/ben3_icon"
			forecolor			1 1 1 0.8
			visible				1

			mouseEnter 
			{ 
				show			ben3_glow
				setitemrect		ben3_glow	25 169 150 150
			}

			mouseExit 
			{ 
				hide			ben3_glow
			}	 
 	  
			action 
			{ 
				play			"sound/interface/button1.wav" ; 
				hide			description ; 
				hide			maulselect ; 
				hide			rightarrow ; 
				hide			leftarrow ; 
				hide			backbutton ; 
				show			background2 ; 
				show			diff_light ;  
				show			backbutton2 ; 
				show			ben3_icon_diff ;
				exec			"set ui_mission_credits_music roteAOEj"
			}
		}


		itemDef 
		{
			name				maulselect
			group				none
			style				WINDOW_STYLE_SHADER
			type				ITEM_TYPE_BUTTON
			rect				465 169 150 150
			background			"gfx/menus/charactericons/mau_cyber_icon"
			forecolor			1 1 1 0.8
			visible				1

			mouseEnter 
			{ 
				show			mau_cyber_glow
				setitemrect		mau_cyber_glow	465 169 150 150
			}

			mouseExit 
			{ 
				hide			mau_cyber_glow
			}	 
 	  
			action 
			{ 
				play			"sound/interface/button1.wav" ; 
				hide			description ; 
				hide			benselect ; 
				hide			rightarrow ; 
				hide			leftarrow ; 
				hide			backbutton ; 
				show			background2 ; 
				show			diff_dark ; 
				show			backbutton2 ; 
				show			mau_cyber_icon_diff ;
				exec			"set ui_mission_credits_music roteAOEs"
			}
		}

