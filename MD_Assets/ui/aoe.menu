		// Difficulty text

		itemDef 
		{
			name				DifficultyButton
			group				diff_light
			style				WINDOW_STYLE_EMPTY
			rect				201 175 240 24 
			text				@MD_MENU_MAIN_SELECT_DIFFICULTY
			textaligny			2
			font				5
			textscale			0.19
			textalign			ITEM_ALIGN_CENTER
			textstyle			3
			textalignx			119
			forecolor			1 1 1 0.9
			visible				0
			decoration
		}

		// Big button Padawan
		itemDef 
		{
			name				easy_light
			group				diff_light
			style				WINDOW_STYLE_EMPTY
			type				ITEM_TYPE_BUTTON
			rect				201 202 240 24
			text				@MD_MENU_MAIN_PADAWAN
			textaligny			2
			font				5
			textscale			0.19
			textalign			ITEM_ALIGN_CENTER
			textstyle			3
			textalignx			119
			forecolor			1 1 1 0.9
			visible				0
  		  	   	  
			mouseEnter 
			{ 
				setitemrect		background_MDMenuPanelGoldMiddle	158.5 200.5 320 30.25
				show			background_MDMenuPanelGoldMiddle
			}  	  
			mouseExit
			{ 
				hide			background_MDMenuPanelGoldMiddle
			}
			action 
			{ 
				play			"sound/interface/button1.wav" ; 
				exec 			"devmap md_luke_jedi"	// Start the new game
                setcvar         helpusobi 1
                exec            "wait 5"
                setcvar         g_spskill 0
				setcvar			handicap 100
                exec			"setforceall 0"
				exec			"cg_sfxsabers 3"
			}
		}

