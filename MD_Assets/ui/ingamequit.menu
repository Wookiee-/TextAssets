	//----------------------------------------------------------------------------------------------
	//
	//	QUIT MENU
	//
	//----------------------------------------------------------------------------------------------
{
	menuDef 
	{
		name				"ingamequitMenu"
		visible				0
		fullScreen			1							// MENU_TRUE				
		rect				0 0 640 480						// Size and position of the menu
		focusColor			1 1 1 1						// Focus color for text and items
		descX				320
		descY				426
		descScale			1
		descColor				1 .682 0 .8
		descAlignment			ITEM_ALIGN_CENTER		

		onOpen
		{
			hide			abandongamegroup ;
			hide			quitprogramgroup ;
			show			quitchoicegroup ;
			setfocus		resume
		}
		onESC 
		{ 
			play			"sound/interface/esc.wav" 	
			hide			abandongamegroup ;
			hide			quitprogramgroup ;
			show			quitchoicegroup ;
			close			all ; 
			open			ingamemainmenu
		}


		//----------------------------------------------------------------------------------------------
		//
		//	MENU BACKGROUND
		//
		//----------------------------------------------------------------------------------------------	

		itemDef //Stop white flash when video loads
		{
			name				background_black
			group				none
			style				WINDOW_STYLE_SHADER
			rect				0 0 640 480
			background			"gfx/menus/main/black"
			forecolor			1 1 1 1
			visible				1
			decoration
		}

		// Main Menu

		itemDef 
		{
			name				background_mainvideo
			group				video
			style				WINDOW_STYLE_SHADER
			rect				0 0 640 480
			background			"gfx/menus/mdmainmenuvideo"
			backcolor			1 1 1 1
			visible				1
			decoration
		}

