		//----------------------------------------------------------------------------------------------
		//
		//   QUIT GAME MENU specific stuff
		//
		//----------------------------------------------------------------------------------------------
		// Quitting title

		itemDef 
		{
			name 				confirm
			group				quitchoicegroup
			text                		@MD_MENU_MAIN_EXIT_MOVIE_DUELS
			rect 				201 202 240 24
			font				5
			textscale 			0.19
			textalign 			ITEM_ALIGN_CENTER
			textstyle			3
			textalignx 			119
			textaligny	 		0
			forecolor			1 1 1 0.9
			visible 			1
			decoration
		}

		// Quit current button
		itemDef 
		{
			name			quitgame_current
			group			quitchoicegroup
			text			@MD_MENU_MAIN_ABANDON_GAME
			type			ITEM_TYPE_BUTTON
			style			WINDOW_STYLE_EMPTY
			rect			201 230 240 24
			font			5
			textscale		0.19
			textalign		ITEM_ALIGN_CENTER
			textstyle		3
			textalignx		119
			textaligny		0
			forecolor		1 1 1 0.9
			visible			1
			
			mouseEnter
			{
				show			background_MDMenuPanelGoldMiddle
			}

			mouseExit
			{
				hide			background_MDMenuPanelGoldMiddle
			}
			action 
			{ 
				play		"sound/interface/button1.wav" ; 
				show		abandongamegroup ;
				hide		quitchoicegroup ;
				hide		quitprogramgroup ;
			}  	  
		}

		// Quit program button
		itemDef 
		{
			name			quitgame_program
			group			quitchoicegroup
			text			@MD_MENU_MAIN_QUIT_PROGRAM
			type			ITEM_TYPE_BUTTON
			style			WINDOW_STYLE_EMPTY
			rect			201 257 240 24
			font			5
			textscale		0.19
			textalign		ITEM_ALIGN_CENTER
			textstyle		3
			textalignx		119
			textaligny		0
			forecolor		1 1 1 0.9
			visible			1
			
			mouseEnter
			{
				show			background_MDMenuPanelGoldBottom
			}

			mouseExit
			{
				hide			background_MDMenuPanelGoldBottom
			}
	      	action 
			{ 
				play		"sound/interface/button1.wav" ; 
				show		quitprogramgroup ;
				hide		abandongamegroup ;
				hide		quitchoicegroup ;
			}  	  
		}


//----------------------------------------------------------------------------------------------
//
//   Abandon game Confirmation
//
//----------------------------------------------------------------------------------------------
// Quit current button
		itemDef 
		{
			name			fakequitgame_current
			group			abandongamegroup
			text			@MD_MENU_MAIN_EXIT_TO_MAIN_MENU
			type			ITEM_TYPE_BUTTON
			style			WINDOW_STYLE_EMPTY
			rect			201 202 240 24
			font			5
			textscale		0.19
			textalign		ITEM_ALIGN_CENTER
			textstyle		3
			textalignx		119
			textaligny		0
			forecolor		1 1 1 0.9
			visible			0
			decoration
		}

		// YES button
		itemDef 
		{
			name			abandongame_yes
			group			abandongamegroup
			text			@MD_MENU_MAIN_YES
			type			ITEM_TYPE_BUTTON
			style			WINDOW_STYLE_EMPTY
			rect			201 230 240 24
			font			5
			textscale		0.19
			textalignx		119
			textaligny		0
			textalign		ITEM_ALIGN_CENTER
			textstyle		3
			forecolor		1 1 1 0.9
			visible			1
			
			mouseEnter
			{
				show			background_MDMenuPanelGoldMiddle
				hide			background_MDMenuPanelGoldBottom
			}

			mouseExit
			{
				hide			background_MDMenuPanelGoldMiddle
			}
	      	action 
			{ 
				play			"sound/interface/button1.wav" ; 
                exec            "seta  com_outcast 0"
			 	hide			abandongamegroup ;
				hide			quitprogramgroup ;
				show			quitchoicegroup ;
				uiScript		Leave	//disconnect and start over
			}	  
		}

		// CANCEL button
		itemDef 
		{
			name			abandongame_cancel
			group			abandongamegroup
			text			@MD_MENU_MAIN_NO
			type			ITEM_TYPE_BUTTON
			style			WINDOW_STYLE_EMPTY
			rect			201 257 240 24
			font			5
			textscale		0.19
			textalignx		119
			textaligny		0
			textalign		ITEM_ALIGN_CENTER
			textstyle		3
			forecolor		1 1 1 0.9
			visible			1
			
			mouseEnter
			{
				show			background_MDMenuPanelGoldBottom
				hide			background_MDMenuPanelGoldMiddle
			}

			mouseExit
			{
				hide			background_MDMenuPanelGoldBottom
			}
			action 
			{ 
				play		"sound/interface/button1.wav" ; 
				hide		abandongamegroup ;
				hide		quitprogramgroup ;
				show		quitchoicegroup ;
				hide		background_MDMenuPanelGoldBottom
				close		all
				open		ingamemainmenu
			}  	  
		}

//----------------------------------------------------------------------------------------------
//
//   Leave game Confirmation
//
//----------------------------------------------------------------------------------------------
// Quit program button
		itemDef 
		{
			name			fakequitgame_program
			group			quitprogramgroup
			text			@MD_MENU_MAIN_QUIT_MOVIE_DUELS
			type			ITEM_TYPE_BUTTON
			style			WINDOW_STYLE_EMPTY
			rect			201 202 240 24
			font			5
			textscale		0.19
			textalign		ITEM_ALIGN_CENTER
			textstyle		3
			textalignx		119
			textaligny		0
			forecolor		1 1 1 0.9
			visible			0
			decoration
		}

		// YES button
		itemDef 
		{
			name			quitprogram_yes
			group			quitprogramgroup
			text			@MD_MENU_MAIN_YES
			type			ITEM_TYPE_BUTTON
			style			WINDOW_STYLE_EMPTY
			rect			201 230 240 24
			font			5
			textscale		0.19
			textalignx		119
			textaligny		0
			textalign		ITEM_ALIGN_CENTER
			textstyle		3
			forecolor		1 1 1 0.9
			visible			1
			
			mouseEnter
			{
				show			background_MDMenuPanelGoldMiddle
				hide			background_MDMenuPanelGoldBottom
			}

			mouseExit
			{
				hide			background_MDMenuPanelGoldMiddle
			}
	      	action 
			{ 
				play			"sound/interface/button1.wav" ;
				exec			"seta  com_outcast 0"
				uiScript		Quit			// Quit the game
			}
	  	  
		}

		// CANCEL button
		itemDef 
		{
			name			quitprogram_cancel
			group			quitprogramgroup
			text			@MD_MENU_MAIN_NO
			type			ITEM_TYPE_BUTTON
			style			WINDOW_STYLE_EMPTY
			rect			201 257 240 24
			font			5
			textscale		0.19
			textalignx		119
			textaligny		0
			textalign		ITEM_ALIGN_CENTER
			textstyle		3
			forecolor		1 1 1 0.9
			visible			1
			
			mouseEnter
			{
				show			background_MDMenuPanelGoldBottom
				hide			background_MDMenuPanelGoldMiddle
			}

			mouseExit
			{
				hide			background_MDMenuPanelGoldBottom
			}
			action 
			{ 
				play		"sound/interface/button1.wav" ; 
				hide		quitprogramgroup ;
				hide		abandongamegroup ;
				show		quitchoicegroup ;
				hide		background_MDMenuPanelGoldBottom
				close		all
				open		ingamemainmenu
			}	  	  
		}

		//----------------------------------------------------------------------------------------------
		//
		//	OTHER MAIN MENU BUTTONS
		//
		//----------------------------------------------------------------------------------------------

		// Big button "BACK"
		itemDef 
		{
			name				exitgamebutton
			group				exit
			text				@MD_MENU_MAIN_BACK
			type				ITEM_TYPE_BUTTON
			style				WINDOW_STYLE_EMPTY
			rect				70 458 101 24
			font				5
			textscale			0.19
			textalign			ITEM_ALIGN_CENTER
			textstyle			3
			textalignx			50
			textaligny			0
			forecolor			1 1 1 0.9
			visible				1
  			
			mouseEnter
			{
					show			background_MDIngameMenuPanelGold

					transition		background_MDIngameMenuPanelGolddivider1 116 468 0 0 70 465 22 12 10 15
					transition		background_MDIngameMenuPanelGolddivider2 116 468 0 0 163 465 22 12 10 15
			}
			mouseExit
			{
					transition		background_MDIngameMenuPanelGolddivider1 70 465 22 12 116 468 0 0 10 15
					transition		background_MDIngameMenuPanelGolddivider2 163 465 22 12 116 468 0 0 10 15

					hide			background_MDIngameMenuPanelGold
			}
			action 
			{ 
				play			"sound/interface/esc.wav" 
				close			all ; 
				open			ingamemainmenu 
			}
		}

		// LOAD button
        itemDef
		{
			name				load
			group				pause
			type				ITEM_TYPE_BUTTON
			rect				170 458 101 24
			text				@MD_MENU_MAIN_LOAD
			font				5
			textscale			0.19
			textalign			ITEM_ALIGN_CENTER
			textstyle			3
			textalignx			50
			textaligny			0
			forecolor			1 1 1 0.9
			visible				1
			
			mouseEnter
			{
					show			background_MDIngameMenuPanelGold

					transition		2background_MDIngameMenuPanelGolddivider1 216 468 0 0 170 465 22 12 10 15
					transition		2background_MDIngameMenuPanelGolddivider2 216 468 0 0 263 465 22 12 10 15
			}
			mouseExit
			{
					transition		2background_MDIngameMenuPanelGolddivider1 170 465 22 12 216 468 0 0 10 15
					transition		2background_MDIngameMenuPanelGolddivider2 263 465 22 12 216 468 0 0 10 15

					hide			background_MDIngameMenuPanelGold
			}
			action
			{
				close			all
				play			"sound/interface/button1.wav" ; 
			    open			ingameloadMenu
			}
		}

		// Big button "SETTINGS"
		itemDef 
		{
			name				settingmenu
			group				pause
			style				WINDOW_STYLE_EMPTY
			type				ITEM_TYPE_BUTTON
