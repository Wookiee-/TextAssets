			textstyle			3
			forecolor			0.5 0.5 0.5 0.9
			visible				1
	  	  	action 
			{
				play			"sound/interface/button1.wav"
				hide effect1
				show effect2
				hide effect3

				setitemcolor	effects1 forecolor 0.5 0.5 0.5 0.9
				setitemcolor	effects2 forecolor 1 1 1 0.9
				setitemcolor	effects3 forecolor 0.5 0.5 0.5 0.9
			} 
		}

