		// Effects

		itemDef 
		{
			name				effects1
			group				none
			rect				170 415 80 18
			text				@MD_MENU_MAIN_EFFECT_ONE
			descText			@MD_MENU_MAIN_EFFECT_DESC
			type				ITEM_TYPE_BUTTON
			textalign			ITEM_ALIGN_LEFT
			font				5
			textscale			0.14
			textstyle			3
			forecolor			1 1 1 0.9
			visible				1
	  	  	action 
			{
				play			"sound/interface/button1.wav"
				show effect1
				hide effect2
				hide effect3

				setitemcolor	effects1 forecolor 1 1 1 0.9
				setitemcolor	effects2 forecolor 0.5 0.5 0.5 0.9
				setitemcolor	effects3 forecolor 0.5 0.5 0.5 0.9
			} 
		}

