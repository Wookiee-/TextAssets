		// BACK button in lower left corner

		itemDef 
		{
			name				backbutton
			group				none
			text				@MD_MENU_MAIN_BACK
			type				ITEM_TYPE_BUTTON
			style				WINDOW_STYLE_EMPTY
			rect				70 458 101 24 
			font				5
			textscale			0.19
			textalign			ITEM_ALIGN_CENTER
			textstyle			3
			textalignx			50
			textaligny			0
			forecolor			1 1 1 0.9
			visible				1

			mouseEnter
			{
					show			background_MDIngameMenuPanelGold

					transition		background_MDIngameMenuPanelGolddivider1 116 468 0 0 70 465 22 12 10 15
					transition		background_MDIngameMenuPanelGolddivider2 116 468 0 0 163 465 22 12 10 15
			}
			mouseExit
			{
					transition		background_MDIngameMenuPanelGolddivider1 70 465 22 12 116 468 0 0 10 15
					transition		background_MDIngameMenuPanelGolddivider2 163 465 22 12 116 468 0 0 10 15

					hide			background_MDIngameMenuPanelGold
			}
			action 
			{ 
				play			"sound/interface/esc.wav" 					
				close			all
				open			ingameMainMenu
			}
		}


		itemDef
		{
			name				weather
			group				none
			type				ITEM_TYPE_MULTI
			rect				170 458.2 301 24
			text				@MD_MENU_SETTINGS_WEATHER
			descText			@MD_MENU_SETTINGS_WEATHER_DESC
			cvar				"r_weather"
			cvarFloatList		
			{  
				@MD_MENU_SETTINGS_CLEAR           0
				@MD_MENU_SETTINGS_SNOW            1
				@MD_MENU_SETTINGS_RAIN            2
				@MD_MENU_SETTINGS_LAVA            3
				@MD_MENU_SETTINGS_SANDSTORM       4
				@MD_MENU_SETTINGS_HEAVY_RAIN_FOG    5
				@MD_MENU_SETTINGS_FOG             6
				@MD_MENU_SETTINGS_ACID_RAIN        7
			}
	   		textalign			ITEM_ALIGN_CENTER
			textalignx			100
			textaligny			0
			font 				5
			textscale			0.19
			forecolor			1 1 1 0.9
			visible			1

			mouseEnter
			{
					show			background_MDIngameMenuPanelGold

					transition		2background_MDIngameMenuPanelGolddivider1 316 468 0 0 170 465 22 12 10 15
					transition		2background_MDIngameMenuPanelGolddivider2 316 468 0 0 463 465 22 12 10 15
			}
			mouseExit
			{
					transition		2background_MDIngameMenuPanelGolddivider1 170 465 22 12 316 468 0 0 10 15
					transition		2background_MDIngameMenuPanelGolddivider2 463 465 22 12 316 468 0 0 10 15

					hide			background_MDIngameMenuPanelGold
			}
			action
			{
				play			"sound/interface/button1.wav"
                exec            "weather clear; wait 100; r_weather";
			}
		}

		// RESUME button in the lower right corner

		itemDef 
		{
			name				resume
			group				resume
			style				WINDOW_STYLE_EMPTY
			type				ITEM_TYPE_BUTTON
			rect				470 458 101 24
			text				@MENUS_RESUME
			font				5
			textscale			0.19
			textalign			ITEM_ALIGN_CENTER
			textstyle			3
			textalignx			50
			textaligny			0
			forecolor			1 1 1 0.9
			visible				1

  			mouseEnter
			{
					show			background_MDIngameMenuPanelGold

					transition		3background_MDIngameMenuPanelGolddivider1 516 468 0 0 470 465 22 12 10 15
					transition		3background_MDIngameMenuPanelGolddivider2 516 468 0 0 563 465 22 12 10 15
			}
			mouseExit
			{
					transition		3background_MDIngameMenuPanelGolddivider1 470 465 22 12 516 468 0 0 10 15
					transition		3background_MDIngameMenuPanelGolddivider2 563 465 22 12 516 468 0 0 10 15

					hide			background_MDIngameMenuPanelGold
			}
			action 
			{ 
				play			"sound/interface/button1.wav" ; 
				uiScript		closeingame					
			}
		}
	}
}









