			font				5
			textscale			0.19
			textalign			ITEM_ALIGN_CENTER
			textstyle			3
			textalignx			65
			textaligny			2
			forecolor			1 1 1 0.9
			desctext			@MENUS_BEGIN_MISSION_DESC
