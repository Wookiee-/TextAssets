//----------------------------------------------------------------------------------------------
		itemDef
		{
			name					backbut
			type					ITEM_TYPE_BUTTON
			rect					30 441 130 20 
			text					@MD_MENU_MAIN_HELP
			font					5
			textscale				0.19
			forecolor				1 1 1 0.9
			textstyle				3
			textalign				ITEM_ALIGN_CENTER
			textalignx				65
			textaligny				2
			visible					1
			mouseEnter 
			{ 
			}
			mouseExit 
			{ 
			}
