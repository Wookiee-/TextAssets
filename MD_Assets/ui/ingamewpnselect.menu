		itemDef
		{
			name				beginmission
			type				ITEM_TYPE_BUTTON
			rect				476 441 130 20  
			text				@MENUS_BEGIN_MISSION
			font				5
			textscale			0.19
			textalign			ITEM_ALIGN_CENTER
			textstyle			3
			textalignx			65
			textaligny			2
			forecolor			1 1 1 0.9
			desctext			@MENUS_BEGIN_MISSION_DESC
			visible			1
			cvartest			"weapon_menu"
			showcvar
			{
				"3"
			}
			mouseEnter 
			{ 
			}
			mouseExit 
			{ 
			}
			action
			{
				play		"sound/interface/menuroam.wav"
				exec "helpUsObi 1"
				exec "maptransition taspir1"
			}
		}

	}
}


