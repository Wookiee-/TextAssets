//----------------------------------------------------------------------------------------------
//	SECOND ROW MENU BUTTONS
//----------------------------------------------------------------------------------------------
		// Setup Options title
		itemDef 
		{
			name				setup_title
			group				title
			style				WINDOW_STYLE_EMPTY
			rect				56 152 240 24
			text				@MD_MENU_SETTINGS_SETUP_OPTIONS
			font				5
			textscale			0.19
			textalign			ITEM_ALIGN_CENTER
			textalignx			119
			textaligny			2
			textstyle			3
			forecolor			1 1 1 0.9
			visible				1
			decoration
		}

		// mdmode  button
		itemDef 
		{
			name				advancedmenubutton
			group				none
			text				@MD_MENU_SETTINGS_COMBAT_OPTIONS
			type				ITEM_TYPE_BUTTON
			style				WINDOW_STYLE_EMPTY
			rect				56 180 240 24
			font				5
			textscale			0.19
			textalignx			119
			textaligny			2
			textalign			ITEM_ALIGN_CENTER
			textstyle			3
			forecolor			1 1 1 0.9
			visible				1

			mouseEnter
			{
				setitemrect		background_MDMenuPanelGoldMiddle	14.75 177.5 320 30.75
				show			background_MDMenuPanelGoldMiddle
			}
			mouseExit
			{
				hide			background_MDMenuPanelGoldMiddle
			}
			action 
			{ 
				play			"sound/interface/button1.wav"

				defer			VideoSetup	videowarningMenu ;

				hide 			video ;
				hide			applyChanges ;
				hide			video2 ;
				hide			rend2 ;
				hide			vidrestart	;
				hide			sound	;
				hide			options ;
				hide			ui_lang ;
				hide			ui ;
				show			advanced ;
				hide			mods	;
				hide			defaults ;
				setitemrect		background_MDMenuPanelGoldMiddleCurrent		14.75 177.5 320 30.75
			}
		}

		// gameoptions  button
		itemDef 
		{
			name				gameoptionmenubutton
			group				none
			text				@MD_MENU_SETTINGS_GAMEPLAY_OPTIONS
