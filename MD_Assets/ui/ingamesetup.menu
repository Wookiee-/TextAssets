//----------------------------------------------------------------------------------------------
//
// SETUP MENU
//
//----------------------------------------------------------------------------------------------
{
	menuDef 
	{
		name					"ingamesetupMenu"
		fullScreen				1						
		rect					0 0 640 480					
		visible					0						
		focusColor				1 1 1 1					
		descX					467
		descY					437
		descScale				0.6
		descColor				1 1 1 0.9
		descAlignment			ITEM_ALIGN_CENTER

		onOpen 
		{
			setfocus			advancedmenubutton
			uiScript			getvideosetup ;			
			hide				applyChanges ;
			hide				video2 ;
			hide				rend2 ;
			hide				vidrestart	;
			hide				sound	;
			hide				options ;
			hide				ui_lang ;
			hide				mods	;
			hide				ui ;
			show				advanced ;
			hide				defaults ;
			hide				video ;
			hide				highlights ;
			setitemrect			background_MDMenuPanelGoldMiddleCurrent	14.75 177.5 320 30.75
			show				background_MDMenuPanelGoldMiddleCurrent
			hide				button_glow
			hide				crosshairs
		}
			
		onESC 
		{ 
			play				"sound/interface/esc.wav" 		

			defer				VideoSetup	videowarningMenu ;

			close				all ;
			open				ingamemainmenu
		}

