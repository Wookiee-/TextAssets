//----------------------------------------------------------------------------------------------
//	NEW GAME MENU BUTTONS
//----------------------------------------------------------------------------------------------
	
		// Text "Choose Your Destiny..."
		itemDef 
		{
			name				newgameText
			group				newgamemenu
			style				WINDOW_STYLE_EMPTY
			type				ITEM_TYPE_BUTTON
			rect				56 175 240 24
			text				@MD_MENU_MAIN_CHOOSE_YOUR_DESTINY
			font				5
			textscale			0.19
			textaligny			2
			textalign			ITEM_ALIGN_CENTER
			textstyle			3
			textalignx			119
			forecolor			1 1 1 0.9
			visible				1
			decoration
		}
			
		// Big button "MISSIONS"
		itemDef 
		{
			name				missionsbutton
			group				newgamemenu
			style				WINDOW_STYLE_EMPTY
			type				ITEM_TYPE_BUTTON
			rect				56 203 240 24
			text				@MD_MENU_MAIN_MISSIONS
			font				5
			textscale			0.19
			textaligny			2
			textalign			ITEM_ALIGN_CENTER
			textstyle			3
			textalignx			119
			forecolor			1 1 1 0.9
			visible				1

			mouseEnter
			{
				setitemrect		background_MDMenuPanelGoldMiddle	15.1 201.5 320 30.25
				show			background_MDMenuPanelGoldMiddle
			}

			mouseExit
			{
				hide			background_MDMenuPanelGoldMiddle
			}

			action 
			{ 
				exec			"soundstop"
				play			"sound/interface/button1.wav" ; 
				exec			"music music/episodeMenu/EP4VideoMusic"
				close			all ; 
				open			episodeMenu
				setitemcolor	background_blackfade backcolor 1 1 1 1	
				fadeout			background_blackfade
			}
		}

		// Big button "DUEL MAPS"
		itemDef 
		{
			name				duelmapsbutton
			group				newgamemenu
			text				@MD_MENU_MAIN_DUEL_MAPS
			style				WINDOW_STYLE_EMPTY
			type				ITEM_TYPE_BUTTON
			rect				56 231 240 24
			textaligny			2
			font				5
			textscale			0.19
