				setitemrect		background_MDMenuPanelGoldMiddle	15.1 228.7 320 30.25
				show			background_MDMenuPanelGoldMiddle
			}

			mouseExit
			{
				hide			background_MDMenuPanelGoldMiddle
			}
			action 
			{ 
				play			"sound/interface/button1.wav" ;
                exec            "seta  com_outcast 0" 
				close			all ; 
				open			duelmapsMenu 
				setitemcolor	background_blackfade backcolor 1 1 1 1	
				fadeout			background_blackfade
			}
		}

		// Big button "CHALLENGE"
