		itemDef
		{
			name				miss1
			group				mission_button
			type				ITEM_TYPE_BUTTON
			rect				265 344 137 15
			text				@MENUS_T3_RIFT_TITLE
			desctext			@MENUS_CLICK_BRIEFING
			font				5
			forecolor			1 .682 0 0.9
			textscale			0.08
			textalign			ITEM_ALIGN_LEFT
			textalignx			8
			textaligny			2
			visible				1
			cvartest			"tiers_complete"
			disablecvar		
			{
				"t3_rift"
			}
			cvarSubString

			mouseEnter 
			{ 
				play			"sound/interface/menuroamjka"
				hide			loc_but01_off
				show			loc_but01_on
				
				show			planet_name
				setitemtext		planet_name	@MENUS_CHANDRILA
				setitemrect		planet_name	379 152 50 20
				
				show			button_glow
				setitemrect		button_glow	258 341 153 17
			}
			mouseExit 
			{ 
				hide			loc_but01_on
				show			loc_but01_off
				
				hide			planet_name
				hide			button_glow
			}
			action
			{
				play			"sound/interface/buttonjka" 
				transition2		background_holo 0 0 640 480 20 25
				transition2		background_galaxy 160 0 320 480 20 25

				transition2		loc_but01_off 410 149 0 0 20 25
				transition2		loc_but02_off 250 189 0 0 20 25
				transition2		loc_but03_off 330 38 0 0 20 25
				transition2		loc_but04_off 408 64 0 0 20 25
				transition2		loc_but05_off 247 114 0 0 20 25
				
				setitemrect		chandrila	139	228	70 70
				fadein			chandrila 
				hide			mission_button
				hide			loc_but01_on
				hide			loc_but02_on
				hide			loc_but03_on
				hide			loc_but04_on
				hide			loc_but05_on
				
				//setitembackground	big_planet	"gfx/menus/planets/chandrila"
				//transition2		big_planet 192 20 256 256 10 15				
				
				fadeout			background_holo
				fadeout			background_galaxy
				show			backbut
				show			accbut1
				
				fadein			briefing_text
				setitemtext		briefing_text	@BRIEFINGS_T3_RIFT				
				
				setitemcolor	planet_name	forecolor 1 .682 0 0.9
				setitemrect		planet_name	316 330 50 15
				fadein			planet_name				
				hide			map_title					
				hide			button_glow
				
			}
		}

