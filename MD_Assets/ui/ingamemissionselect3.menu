//----------------------------------------------------------------------------------------------
//	BUTTONS
//----------------------------------------------------------------------------------------------
		//GENERAL BACK BUTTON - if you don't want mission
		itemDef
		{
			name				backbut
			type				ITEM_TYPE_BUTTON
			rect				272 434 50 20
			text				@MENUS_BACK_CAPS
			desctext			@MENUS_DIFF_MISSION
			font				5
			forecolor			1 0 0 0.9
			textscale			0.085
			textalign			ITEM_ALIGN_LEFT
			textalignx			13
			textaligny			2
			visible			0
			mouseEnter 
			{ 
				play			"sound/interface/menuroamjka"
				show			button_glow
				setitemrect		button_glow	261 431 70 20
			}
			mouseExit 
			{ 
				hide			button_glow
			}
			action
			{
				play			"sound/interface/buttonjka" 					
				fadein			background_holo
				fadein			background_galaxy
				transition2		loc_but01_off 384 133 25 25 20 25
				transition2		loc_but02_off 234 173 25 25 20 25
				transition2		loc_but03_off 320 28 13 13 20 25
				transition2		loc_but04_off 395 51 19 19 20 25
				transition2		loc_but05_off 233 100 21 21 20 25
				hide			backbut
				
				hide			planet_name
		
				show			mission_button
				
				hide			accbuttons
				
				hide			briefing_text
				
				hide			big_planet
				
				setitemcolor	planet_name	forecolor .549 .854 1 0.7
				hide			planet_name
				show			map_title					
				
				hide 			briefing_text

				hide			button_glow
			}
		}

		itemDef
		{
			name				planet_name
			type				ITEM_TYPE_TEXT
			rect				52 316 288 24
			font				5
			forecolor			.549 .854 1 0.7
			textscale			0.085
			textalign			ITEM_ALIGN_CENTER
			textalignx			8
			textaligny			2
			visible				0
			autowrapped
			decoration
		}

//----------------------------------------------------------------------------------------------
//  TIER 3 MISSION BUTTONS
//----------------------------------------------------------------------------------------------
		itemDef
		{
			name				map_title
			type				ITEM_TYPE_TEXT
			rect				324 330 50 15
			text				@MENUS_MISSIONS
			font				5
			forecolor			1 .682 0 0.9
			textscale			0.085
			textalign			ITEM_ALIGN_CENTER
			textalignx			8
