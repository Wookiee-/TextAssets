		//----------------------------------------------------------------------------------------------
		//
		//	CAMERA BUTTONS
		//
		//----------------------------------------------------------------------------------------------

		itemDef 
		{
			name				presetcameraTextHideAll
			group				camHideAll
			style				WINDOW_STYLE_FILLED
			rect				393 119 240 24
			forecolor			1 1 1 0
			visible				1
			decoration
			mouseEnter
			{
				hide			background
				hide			cam
				hide			camera_options	
				hide			pause
				hide			backgroundpanel
				hide			background_logo
			}
			mouseExit
			{
				show			background
				show			cam
				show			camera_options
				show			pause
				show			backgroundpanel
				show			background_logo
			}
		}

		// Text "Presets"
		itemDef 
		{
			name				presetcameraText
			group				cam
			style				WINDOW_STYLE_EMPTY
			type				ITEM_TYPE_BUTTON
			rect				393 120 240 24
			text				@MD_MENU_MAIN_CAMERA_PRESETS
			font				5
			textscale			0.19
			textaligny			0
			textalign			ITEM_ALIGN_CENTER
			textstyle			3
			textalignx			119
			forecolor			1 1 1 0.9
			visible				1
			decoration
		}
		
		// Big button "NORMAL"
		itemDef 
		{
			name				challenge_begin1
			group				cam
			style				WINDOW_STYLE_EMPTY
			type				ITEM_TYPE_BUTTON
			rect				393 147 240 24 
			text				@MD_MENU_MAIN_NORMAL2
			font				5
			textscale			0.19
			textaligny			0
			textalign			ITEM_ALIGN_CENTER
			textstyle			3
			textalignx			119
			forecolor			1 1 1 0.9
			visible				1
	  	  
			mouseEnter
			{
				setitemrect		background_MDMenuPanelGoldMiddle	351 143 320 30.25
				show			background_MDMenuPanelGoldMiddle
			}
			mouseExit
			{
				hide			background_MDMenuPanelGoldMiddle
			}
			action 
			{ 
				exec			"seta cg_thirdPersoncameradamp 1"
				play			"sound/interface/button1.wav" ; 
				exec			"cg_fov 80" 			
				exec			"seta cg_thirdPersonrange 80"
				exec			"seta cg_thirdPersonpitchoffset 0"
				exec			"seta cg_thirdPersonvertoffset 16"
				exec			"seta cg_thirdPersonhorzoffset 0"
				exec			"seta cg_thirdPersontargetdamp 0.5"
				exec			"seta cg_thirdPersonangle 0"
				exec			"cm_noAreas 0"
				exec			"wait 100"
				exec			"seta cg_thirdPersoncameradamp 0.4"
			}
		}

		// Big button "CLOSE"
		itemDef 
		{
			name				challenge_begin1
			group				cam
			style				WINDOW_STYLE_EMPTY
			type				ITEM_TYPE_BUTTON
			rect				393 175 240 24 
			text				@MD_MENU_MAIN_CLOSE_CAM
			font				5
			textscale			0.19
			textaligny			0
			textalign			ITEM_ALIGN_CENTER
			textstyle			3
			textalignx			119
			forecolor			1 1 1 0.9
			visible				1
	  	  
			mouseEnter
			{
				setitemrect		background_MDMenuPanelGoldMiddle	351 171 320 30.25
				show			background_MDMenuPanelGoldMiddle
			}
			mouseExit
			{
				hide			background_MDMenuPanelGoldMiddle
			}
			action 
			{ 
				play			"sound/interface/button1.wav" ; 
				exec			"cg_fov 64.453125" 
				exec			"seta cg_thirdPersonrange 85.937500"
				exec			"seta cg_thirdPersonpitchoffset 9.765625"
				exec			"seta cg_thirdPersonvertoffset -3.125000"
				exec			"seta cg_thirdPersonhorzoffset 0"
				exec			"seta cg_thirdPersontargetdamp 1"
				exec			"seta cg_thirdPersoncameradamp 1"
				exec			"seta cg_thirdPersonangle 0"
				exec			"cm_noAreas 0"
				//close			all ; 
			}
		}

