//----------------------------------------------------------------------------------------------
//
//	CUSTOM CAMERA MENU
//
//----------------------------------------------------------------------------------------------
{
	menuDef
	{
		name					"ingamecameraMenu"
		fullScreen				0									// MENU_TRUE
		rect					0 0 640 480							// Size and position of the menu
		focusColor				1 1 1 1				// Focus color for text and items
		descX					320
		descY					440
		descScale				0.7
		descColor				1 1 1 0.9
		descAlignment			ITEM_ALIGN_CENTER	
		descTextStyle			1
		visible					0									// Visible on open

		onOpen
		{
			exec				"helpUsObi 1"
			setfocus			resume ;
			show				background
			show				cam
			show				camera_options
			show				pause
			show				backgroundpanel
			show 				background_logo
		}

		onESC
		{
				play			"sound/interface/esc.wav"  
				close			all ; 
				open			ingameMainMenu 
		}

