//----------------------------------------------------------------------------------------------
//
// CONTROLS MENU
//
//	Player can change key bindings from main menu
//
//----------------------------------------------------------------------------------------------
{
	menuDef 
	{
		name					"ingamecontrolsMenu"
		fullScreen				1						
		rect					0 0 640 480					
		visible					1						
		focusColor				1 1 1 1						
		descX					467
		descY					437
		descScale				0.6
		descColor				1 1 1 0.9
		descAlignment			ITEM_ALIGN_CENTER	

		onOpen 
		{
				setfocus			movementcontrolbutton
				uiScript 		loadControls
				show			movecontrols
				hide 			attackcontrols			
				hide 			weaponcontrols	
				hide			forcecontrols
				hide 			quickcontrols
				hide			joycontrols
				hide			othercontrols
				hide			ffwarning
				setitemrect			background_MDMenuPanelGoldMiddleCurrent	14.75 177.5 320 30.25
				show				background_MDMenuPanelGoldMiddleCurrent
		}

		onClose 
		{
			uiScript 			saveControls
			hide				ffwarning
		}
									
		onESC 
		{ 
			play				"sound/interface/esc.wav" 
			hide				button_glow
			close				controlsMenu
			open				ingamesetupMenu 
			hide				ffwarning
		}

