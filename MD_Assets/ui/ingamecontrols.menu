//----------------------------------------------------------------------------------------------
//	MOVEMENT BINDING
//----------------------------------------------------------------------------------------------
		itemDef 
		{
			name				movement1
			group				movecontrols
			type				ITEM_TYPE_BIND
			text				@MENUS_WALK_FORWARD
			cvar				"+forward"
			rect				315 158 305 14
			textalign			ITEM_ALIGN_RIGHT
			textalignx			150 
			textaligny			0
			font				5
			textscale			0.14
			forecolor			1 1 1 0.9
			visible			0
			descText			@MENUS_MOVES_PLAYER_FORWARD
			action 
			{ 
				play			sound/interface/button1
			}

			mouseenter 
			{
				show			button_glow
				setitemrect		button_glow	315 159 305 14
			}
			mouseexit 
