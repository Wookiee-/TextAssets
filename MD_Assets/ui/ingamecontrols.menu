//----------------------------------------------------------------------------------------------
//	SIDE BUTTONS
//----------------------------------------------------------------------------------------------
		// Configure Controls title
		itemDef 
		{
			name				control_title
			group				title
			style				WINDOW_STYLE_EMPTY
			text				@MD_MENU_SETTINGS_CONFIGURE_CONTROLS
      		rect				56 152 240 24
			font				5
			textscale			0.19
			textalign			ITEM_ALIGN_CENTER
			textalignx			119
			textaligny			2
			textstyle			3
			forecolor			1 1 1 0.9
      		visible				1
			decoration
		}
		
//----------------------------------------------------------------------------------------------
// GLOW ON SIDE BUTTONS
//----------------------------------------------------------------------------------------------
		itemDef 
		{
			name				sidebutton_glow
			group				none
			style				WINDOW_STYLE_SHADER
			rect				60 155 200 24
			background			"gfx/menus/menu_blendbox2"			// Frame around button
			forecolor			1 1 1 1
			visible				0
			decoration
		}

		itemDef 
		{
			name				button_glow
			group				none
			style				WINDOW_STYLE_SHADER
			rect				0 0 0 0
			background			"gfx/menus/menu_blendbox"
			forecolor			1 1 1 1
			visible				0
			decoration
		}
		
//----------------------------------------------------------------------------------------------
// MOVEMENT  button
//----------------------------------------------------------------------------------------------
		itemDef 
		{
			name				movementcontrolbutton
			group				side_buttons
			text				@MENUS_MOVEMENT
			type				ITEM_TYPE_BUTTON
			style				WINDOW_STYLE_EMPTY
			rect				56 180 240 24
			font				5
			textscale			0.19
			textalignx			119
			textaligny			2
			textstyle			3
			textalign			ITEM_ALIGN_CENTER
			forecolor			1 1 1 0.9
			visible				1
			
			mouseEnter
			{
				setitemrect		background_MDMenuPanelGoldMiddle	14.75 177.5 320 30.25
				show			background_MDMenuPanelGoldMiddle
			}

			mouseExit
			{
				hide			background_MDMenuPanelGoldMiddle
			}
			action 
			{ 
				play			"sound/interface/button1.wav"
				show			movecontrols 	
				hide 			attackcontrols 	
				hide 			weaponcontrols 	
				hide			forcecontrols 
				hide 			quickcontrols 
				hide			joycontrols 
				hide			othercontrols 
				setitemrect		background_MDMenuPanelGoldMiddleCurrent		14.75 177.5 320 30.75
			}
		}

