		itemDef
		{
			name				Stats
			type				ITEM_TYPE_TEXT
			rect				177 118 200 32
			text				@MD_MENU_MAIN_MISSION_STATS_OVERVIEW
			font				5
			forecolor			0.8 0.8 0.8 0.9
			textscale			0.14
			textalign			ITEM_ALIGN_CENTER
			textalignx			0
			textaligny			0
			visible				1
			decoration
		}

		
