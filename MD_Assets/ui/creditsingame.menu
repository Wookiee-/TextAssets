//-----------------------------------------------------------------------
// MISSION STATS MENU FOR MD
//
//	Called from all other menus other than main menu. This has no transition in it.
//
//-----------------------------------------------------------------------
{						   
	menuDef 
	{
		name					"creditsingame"
		fullScreen				1						// MENU_TRUE				
		rect					0 0 640 480					// Size and position of the menu
		visible					0						// Visible on open
		focusColor				1 1 1 1			// Focus color for text and items
		descX					252
		descY					438
		descScale				0.6
		descColor				1 1 1 0.9
		descAlignment			ITEM_ALIGN_CENTER		
		
		fadeClamp				1.0						// sets the fadeup alpha
		fadeCycle				50						// how often fade happens in milliseconds
		fadeAmount				0.05					// amount to adjust alpha per cycle

		onOpen
		{
			exec			"soundstop"
			setfocus		musicbutton
			fadeout			black
			transition2		musicbutton 0 0 640 480 5 5
		}

		onESC 
		{ 
			uiscript		leave
		}

		//----------------------------------------------------------------------------------------------
		//
		//	MENU BACKGROUND
		//
