//----------------------------------------------------------------------------------------------
// CHARACTER CREATION MENU
//
//	
//
//----------------------------------------------------------------------------------------------
{						   
	menuDef 
	{
		name					"characterMenu"
		fullScreen				1			
		rect					0 0 640 480	
		visible					1		
		focusColor				1 1 1 1
		descX					320
		descY					426
		descScale				1
		descColor				1 .682 0 .8
		descAlignment			ITEM_ALIGN_CENTER
	
		fadeClamp				1.0					// sets the fadeup alpha
		fadeCycle				25					// how often fade happens in milliseconds
		fadeAmount				0.05				// amount to adjust alpha per cycle	

		onOpen
		{ 
			uiScript 		 	"getcharcvars"
			uiScript 		 	"character"
			//setcvar             "g_char_skin_head" "head_a1"
			//setcvar				"g_char_skin_torso" "torso_a1"
			//setcvar 			"g_char_skin_legs" "lower_a1"
			//exec				"set g_char_skin_head head_a1"
			//exec				"set g_char_skin_legs lower_a1"
			//exec                "set g_char_skin_torso torso_a1"
			setitemrect			character 98 79 700 800
			setitemrect			background 0 0 640 480
			hide				heads
			hide				colour
			hide				tints2
			hide				torso
			hide				lower
			hide				glow
			hide				charmenubuttonhide
			hide				charmenubuttonshow
			setitemcolor		colorrgbbut forecolor 0.5 0.5 0.5 0.9
			setitemcolor		colorpresetbut forecolor 1 1 1 0.9

			hide				charmenu
			show				speciemenu
			hide				femalespecie
			show				malespecie
			setitemcolor		specie_male forecolor 1 1 1 0.6
			setitemcolor		specie_female forecolor 0.5 0.5 0.5 0.6
		}
									
		onESC 
		{ 
			uiScript 			"updatecharcvars"
			exec				"soundstop"
			play				"sound/interface/esc.wav" 	
			exec				"menumusic"
			setitemrect			character 98 79 700 800
			setitemrect			background 0 0 640 480
			hide				heads
			hide				colour
			hide				tints2
			hide				torso
			hide				lower
			close				all
			open				mdnewgameMenu
		}

