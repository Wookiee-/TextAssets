//----------------------------------------------------------------------------------------------
//   CHARACTER MENU specific stuff
//----------------------------------------------------------------------------------------------
		// CREATION title

		itemDef 
		{
			name				creation_title
			group				charmenu
			style				WINDOW_STYLE_EMPTY
			rect				235 30 170 20
			text				@MD_MENU_MAIN_CHARACTER_CREATION
			font				5
			textscale			0.19
			textaligny			0
			textalign			ITEM_ALIGN_CENTER
			textstyle			3
			textalignx			85
			forecolor			1 1 1 0.9
			visible				1
			decoration
		}

		itemDef
		{
			name				character
			group				none
			type 				ITEM_TYPE_MODEL
			rect				154 79 125 50
			
			model_g2anim 		"BOTH_MENUIDLE1"
			asset_model			"ui_char_model"
			model_angle			180
			model_g2mins		-26 -31 -26
			model_g2maxs		20 15 30
			model_fovx			50
			model_fovy			50
			cvar				ui_char_model_angle
			//isSaber			1
			//isSaber2			1
			isCharacter			1
			visible				1
			decoration	
		}
	
