//-----------------------------------------------------------------------
//	CHARACTERSPAWN MENU
//
//	Called only from main menu. Has the transition of fields from main menu 
//	to new game menu
//
//-----------------------------------------------------------------------
{
						   
	menuDef 
	{
		name					"ingamespawncommandsMenu"
		fullScreen				1						// MENU_TRUE				
		rect					0 0 640 480					// Size and position of the menu
		visible					0						// Visible on open
		focusColor				1 1 1 0.9					// Focus color for text and items
		descX					320
		descY					384
		descScale				0.82
		descColor				1 1 1 0.9
		descAlignment			ITEM_ALIGN_CENTER	
		descTextStyle			1	
		//popup
		//outOfBoundsClick

		onOpen
		{ 
			exec				"aiworkshop"
			exec				"workshop_select"
			hide				PREVIEW_ICON
		}
									
		onESC
		{ 
			play				"sound/interface/esc.wav" 
			close				ingamespawncommandsMenu
			exec				"aiworkshop"
		}

