		itemDef
		{
			name				title
			group				commands
			type				ITEM_TYPE_TEXT
			textalign			ITEM_ALIGN_CENTER
			rect				320 103 100 20
			text				@MD_MENU_MAIN_NPC_COMMANDS_MENU
			font				5
			textscale			0.19
			textstyle			1
			forecolor			1 1 1 0.9
			visible				1
			decoration
		}

		itemDef 
		{
			name				nonpcselected
			group				none
			style				WINDOW_STYLE_SHADER
			rect				50 179 105 105
			background			"gfx/menus/charactericons/nonpcselected_icon"
			forecolor			1 1 1 1
			visible				0
			decoration
		}

		itemDef 
		{
			name				helpbutton
			group				none
			style				WINDOW_STYLE_EMPTY
			type				ITEM_TYPE_BUTTON
			text				@MD_MENU_MAIN_CLOSE_HELP
			descText			@MD_MENU_MAIN_CLOSE_HELP_DESC
			rect				70 458 101 24
			font				5
			textscale			0.19
			textalign			ITEM_ALIGN_CENTER
			textstyle			3
			textalignx			50
			textaligny			0
			forecolor			1 1 1 0.9
			visible				1

			mouseEnter
			{
					show			background_MDIngameMenuPanelGold

					transition		background_MDIngameMenuPanelGolddivider1 116 468 0 0 70 465 22 12 10 15
					transition		background_MDIngameMenuPanelGolddivider2 116 468 0 0 163 465 22 12 10 15
			}
			mouseExit
			{
					transition		background_MDIngameMenuPanelGolddivider1 70 465 22 12 116 468 0 0 10 15
					transition		background_MDIngameMenuPanelGolddivider2 163 465 22 12 116 468 0 0 10 15

					hide			background_MDIngameMenuPanelGold
			}
			action 
			{ 
					play				"sound/interface/esc.wav" 
					close				ingamespawncommandsMenu
					exec				"aiworkshop"
			}
		}	

		itemDef 
		{
			name				NPCfreeze
			group				comm
			style				WINDOW_STYLE_EMPTY
			type				ITEM_TYPE_MULTI
			rect				170 458 301 24 
			text				@MD_MENU_MAIN_FREEZE_NPC
			descText			@MD_MENU_MAIN_FREEZE_NPC_DESC
			cvar				"d_npcfreeze"	
			cvarFloatList		{ @MD_MENU_MAIN_OFF 0 @MD_MENU_MAIN_ON 1 }
			font				5
			textscale			0.19
			textaligny			0
			textalign			ITEM_ALIGN_CENTER
			textstyle			3
			textalignx			135
			forecolor			1 1 1 0.9
			visible				1
			
			mouseEnter
			{
					show			background_MDIngameMenuPanelGold

					transition		2background_MDIngameMenuPanelGolddivider1 316 468 0 0 170 465 22 12 10 15
					transition		2background_MDIngameMenuPanelGolddivider2 316 468 0 0 463 465 22 12 10 15
			}
			mouseExit
			{
					transition		2background_MDIngameMenuPanelGolddivider1 170 465 22 12 316 468 0 0 10 15
					transition		2background_MDIngameMenuPanelGolddivider2 463 465 22 12 316 468 0 0 10 15

					hide			background_MDIngameMenuPanelGold
			}
	  	  	action 
			{
				play			"sound/interface/button1.wav"
				exec			"helpusobi 1"
			} 
		}

		itemDef 
		{
			name				resume
			group				none
			style				WINDOW_STYLE_EMPTY
			type				ITEM_TYPE_BUTTON
			text				@MD_MENU_MAIN_RESUME
			textalign			ITEM_ALIGN_LEFT
			rect				470 458 101 24 
			font				5
			textscale			0.19
			textalign			ITEM_ALIGN_CENTER
			textstyle			3
			textalignx			50
			textaligny			0
			forecolor			1 1 1 0.9
			visible				1
			
			mouseEnter
			{
					show			background_MDIngameMenuPanelGold

					transition		5background_MDIngameMenuPanelGolddivider1 516 468 0 0 470 465 22 12 10 15
					transition		5background_MDIngameMenuPanelGolddivider2 516 468 0 0 563 465 22 12 10 15
			}
			mouseExit
			{
					transition		5background_MDIngameMenuPanelGolddivider1 470 465 22 12 516 468 0 0 10 15
					transition		5background_MDIngameMenuPanelGolddivider2 563 465 22 12 516 468 0 0 10 15

					hide			background_MDIngameMenuPanelGold
			}
	  	  	action 
			{
				play			"sound/interface/button1.wav" ; 
				uiScript		closeingame		
				exec			"aiworkshop"
			} 
		}

		//----------------------------------------------------------------------------------------------
		//
		//	NPC COMMANDS
		//
		//----------------------------------------------------------------------------------------------

		// Sub Buttons


		itemDef
		{
			name				npccommandsteam
			group				subbuttoncommands
			type				ITEM_TYPE_BUTTON
			rect				35 421 95 25
			text				@MD_MENU_MAIN_NPC_TEAM
			descText			@MD_MENU_MAIN_NPC_TEAM_DESC
			font				5
			textscale			0.16
			textstyle			1
			forecolor			1 1 1 0.9
			textalignx			15
			textaligny			3
			visible			1
			action
			{
				hide			health	
				show			team
				hide			action
				hide			PREVIEW_ICON
				hide			action1
				hide			action2
				hide			action3
				hide			scripts
				hide			scriptsgeneral
				hide			scriptswounded
				hide			scriptspain
				hide			scriptsdeath
				hide			scriptsvictory
				hide			scriptsseen
				hide			force
				hide			npcforcesub	
				hide			npcforcelight
				hide			npcforcedark
				hide			npcforceneutral
				hide			npcforceall
				hide			weapon
				hide			weapon_icon
				hide			hilts
				hide			sabercolor

				setitemcolor	npccommandsteam forecolor 1 1 1 0.9
				setitemcolor	npccommandshealth forecolor 0.5 0.5 0.5 0.9
				setitemcolor	npccommandsscripts forecolor 0.5 0.5 0.5 0.9
				setitemcolor	npccommandsactions forecolor 0.5 0.5 0.5 0.9
				setitemcolor	npccommandsforce forecolor 0.5 0.5 0.5 0.9
				setitemcolor	npccommandsweapons forecolor 0.5 0.5 0.5 0.9
			}
		}


		itemDef
		{
			name				npccommandshealth
			group				subbuttoncommands
			type				ITEM_TYPE_BUTTON
			textalign			ITEM_ALIGN_LEFT
