//----------------------------------------------------------------------------------------------
//	SABER COMBAT STYLES
//----------------------------------------------------------------------------------------------
		
		itemDef 
		{
			name				new_fightingstyle_button
			group				none
			text				@MD_MENU_SABER_LIGHTSABER_STYLE
			type				ITEM_TYPE_MULTI
			style				WINDOW_STYLE_EMPTY
			rect				216 72 130 24
			font				5
			textscale			0.19
			textalign			ITEM_ALIGN_LEFT
			textstyle			3
			textalignx			10
			textaligny			1
			forecolor			1 1 1 0.9
			
			cvar				"saberStyleDescriptions"
			cvarStrList
			{
				@MD_MENU_SABER_FAST_STANCE		"0"
				@MD_MENU_SABER_MEDIUM_STANCE		"1"
				@MD_MENU_SABER_STRONG_STANCE		"2"
				@MD_MENU_SABER_DUAL_STANCE		"3"
				@MD_MENU_SABER_STAFF_STANCE		"4"
				@MD_MENU_SABER_DESANN_STANCE		"5"
				@MD_MENU_SABER_TAVION_STANCE		"6"
			}

			visible				1
			 
			mouseEnter 
			{ 
				show			sabermenu_saberstyleglow
				show			new_fightingstyle_desc
			}
			mouseExit 
			{ 
				hide			sabermenu_saberstyleglow
				hide			new_fightingstyle_desc
			}	  	  
			action 
			{
				play			"sound/interface/button1.wav" 
			}
		}
		
