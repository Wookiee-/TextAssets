//----------------------------------------------------------------------------------------------
//	LIGHTSABER TABS
//----------------------------------------------------------------------------------------------

		itemDef 
		{
			name				typebut
			group				sabermenubutton
			text				@MD_MENU_SABER_SABER
			type				ITEM_TYPE_BUTTON
			style				WINDOW_STYLE_EMPTY
			rect				25 152 120 68
			textalign			ITEM_ALIGN_RIGHT
			font				5
			textscale			0.19
			textaligny			27
			textstyle			3
			textalignx			110
			backcolor			0 0 0 0
			forecolor			1 1 1 0.9
			visible				1

			mouseEnter 
			{ 
				show			sabermenu_saberglow
			}
			mouseExit 
			{ 
				hide			sabermenu_saberglow	
			}
			action 
			{
