			name				rgbicon2
			group				sabercolors2
			style				WINDOW_STYLE_SHADER
			type				ITEM_TYPE_BUTTON
			rect				467 360 21 21
			background			"gfx/menus/sp/saber/saber_icon_rgb"
			forecolor			1 1 1 0.7
			desctext			"RGB"
			visible				0
			
			mouseEnter 
			{ 
				setitemcolor		rgbicon2 forecolor 1 1 1 1
			}
			mouseExit 
			{ 
				setitemcolor		rgbicon2 forecolor 1 1 1 0.7
			}	
			action 
			{
				play			"sound/interface/choose_blade.wav"
				hide			sabercolors2
				show			rgbcolors2
				exec 			"ui_saber2_color rgb"
				uiScript  		"getsabercvars"
			}
		}

