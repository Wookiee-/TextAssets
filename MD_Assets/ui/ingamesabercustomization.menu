		itemDef 
		{
			name				sfxsabers
			group				crystal
			type				ITEM_TYPE_MULTI
			cvar				"cg_sfxsabers"
			cvarFloatList		
			{
				"JKA"	          		0  
				"TPM"   	          	1 
				"AOTC" 	                2 
				"ROTS"  	            3
				"ANH"	                4
				"ESB"                   5 
				"ROTJ"                  6  
				"TFA"                   7
				"UNSTABLE"              8  
				"REBELS"				9
			}
			text				@MD_MENU_SABER_SABER_BLADE
			rect				350.5 159 120 20
	   		textalign			ITEM_ALIGN_RIGHT
			textalignx			70
			textaligny			2
			font 				5
			textscale 			0.14
			forecolor			1 1 1 0.9
			visible				0
		
			action 
			{ 
				play			"sound/interface/button1.wav"
				exec  			"cg_SFXSabersGlowSize 1 ; cg_SFXSabersCoreSize 1"
				exec 			"cg_SFXSabersGlowSizeEP1 1 ; cg_SFXSabersCoreSizeEP1 1"
				exec			"cg_SFXSabersGlowSizeEP2 1 ; cg_SFXSabersCoreSizeEP2 1"
				exec			"cg_SFXSabersGlowSizeEP3 1 ; cg_SFXSabersCoreSizeEP3 1"
				exec			"cg_SFXSabersGlowSizeSFX 1 ; cg_SFXSabersCoreSizeSFX 1"
				exec			"cg_SFXSabersGlowSizeOT 1 ; cg_SFXSabersCoreSizeOT 1"
				exec			"cg_SFXSabersGlowSizeROTJ 1 ; cg_SFXSabersCoreSizeROTJ 1"
 				exec			"cg_SFXSabersGlowSizeTFA 1 ; cg_SFXSabersCoreSizeTFA 1"
				exec	  		"cg_SFXSabersGlowSizeUSB 1 ; cg_SFXSabersCoreSizeUSB 1"
				exec	  		"cg_SFXSabersGlowSizeRebels 0.6 ; cg_SFXSabersCoreSizeRebels 0.6"
			}
		}

