//-----------------------------------------
// Go to Academy (taken from ingameMissionSelect)
//----------------------------------------
		itemDef
		{
			name				story5_continue
			type				ITEM_TYPE_BUTTON
			rect				430 312 55 73
			forecolor			1 1 1 0
			visible			1
			cvartest			"tier_storyinfo"
			showCvar			{ "5"; "6" }
			mouseEnter 
			{ 
				play			"sound/interface/menuroamjka"
				setitemcolor	background_nextpanel backcolor 1 1 1 1
			}
			mouseExit 
			{ 
				setitemcolor	background_nextpanel backcolor 1 1 1 0.8
			}
			action
			{
				play			"sound/interface/buttonjka"
				close			all
				uiScript		startmap academy2
			}
		}

