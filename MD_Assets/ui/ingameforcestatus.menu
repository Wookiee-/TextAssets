			group				none
			style				WINDOW_STYLE_FILLED
			rect				0 0 640 480
			background			"gfx/menus/ingame/jkamissionshipbk"
			backcolor			1 1 1 1
			visible				1
			decoration
		}
		
		itemDef 
		{
			name				background_screen_luke
			group				none
			style				WINDOW_STYLE_FILLED
			rect				266 326 140 96
			background			"gfx/menus/ingame/jkamissionlukebk"
			backcolor			1 1 1 1
			visible				1
			decoration
			cvarTest			ui_forcestatus
			showCvar			{ "vll"; "sll"; "ntl"; "sdl"; "vdl"  }
		}
		
		itemDef 
		{
			name				background_screen_kyle
			group				none
			style				WINDOW_STYLE_FILLED
			rect				266 326 140 96
			background			"gfx/menus/ingame/jkamissionkylebk"
			backcolor			1 1 1 1
			visible				1
			decoration
			cvarTest			ui_forcestatus
			showCvar			{ "vlk"; "slk"; "ntk"; "sdk"; "vdk"  }
		}


		// Allocate force point
		itemDef
		{
			name				allocate_text
			type				ITEM_TYPE_TEXT
			rect				320 12 200 32
			text				@MENUS_CUR_FORCE_ALLOC
			font				2
			forecolor			.549 .854 1 0.7
			textscale			0.6
			textalign			ITEM_ALIGN_CENTER
			textalignx			0
			visible			1
			decoration
		}

