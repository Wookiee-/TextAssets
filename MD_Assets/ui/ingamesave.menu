//------------------------------------------------------------------------------------------------
// INGAME MAIN MENU
//
//	Allows player to save current game
//
//------------------------------------------------------------------------------------------------
{
	menuDef 
	{
		name					"ingamesaveMenu"
		fullScreen				1								// MENU_TRUE				
		rect					0 0 640 480						// Size and position of the menu
		visible					1								// Visible on open
		focusColor				1 1 1 1							// Focus color for text and items
		descX					320
		descY					426
		descScale				1
		descColor				1 .682 0 0
		descAlignment				ITEM_ALIGN_CENTER		
		disablecolor				.7 .7 .7 1

		onOpen 
		{
			uiScript			ReadSaveDirectory
			setfocus			savegamedesc
		}

		onESC 
		{ 
			play				"sound/interface/esc.wav" 					
			close				all
			open				ingamemainMenu
		}
												
//----------------------------------------------------------------------------------------------
//	MENU BACKGROUND
//----------------------------------------------------------------------------------------------
		itemDef //Stop white flash when video loads
		{
			name				background_black
			group				none
			style				WINDOW_STYLE_SHADER
			rect				0 0 640 480
			background			"gfx/menus/main/black"
			forecolor			1 1 1 1
			visible				1
			decoration
		}	

		itemDef 
		{
			name				background_mainvideo
			group				mainmenuvideo
			style				WINDOW_STYLE_SHADER
			rect				0 0 640 480
			background			"gfx/menus/mdmainmenuvideo"
			backcolor			1 1 1 1
			visible				1
			decoration
		}

		itemDef 
		{
			name				background
			group				none
			style				WINDOW_STYLE_SHADER
			rect				0 0 640 480
