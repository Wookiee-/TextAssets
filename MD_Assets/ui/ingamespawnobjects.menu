		itemDef 
		{
			name				toss_heater
			group				objects
			style				WINDOW_STYLE_SHADER
			type				ITEM_TYPE_BUTTON
			rect				38 110 85 85
			background			"gfx/menus/charactericons/toss_heater_icon"
			forecolor			1 1 1 0.8
			visible				1
			descText			@MD_MENU_MAIN_TOSS_HEATER

			mouseEnter 
			{ 
				show			toss_heater_glow
				setitemrect		toss_heater_glow	38 110 85 85
			}

			mouseExit 
			{ 
				hide			toss_heater_glow
			}	 
 	  
			action 
			{  
				close			all ; 
				exec			"helpusobi 1"
				exec			"set npc_spawn_recent npc spawn toss_heater toss_heater"
				exec			"vstr npc_spawn_recent"
			}
		}

