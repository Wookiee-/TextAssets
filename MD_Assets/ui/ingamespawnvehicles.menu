		itemDef 
		{
			name				atst
			group				vehicles
			style				WINDOW_STYLE_SHADER
			type				ITEM_TYPE_BUTTON
			rect				38 110 85 85
			background			"gfx/menus/charactericons/atst_veh_icon"
			forecolor			1 1 1 0.8
			visible				1
			descText			@MD_MENU_MAIN_ATST

			mouseEnter 
			{ 
				show			atst_veh_glow
				setitemrect		atst_veh_glow	38 110 85 85
			}

			mouseExit 
			{ 
				hide			atst_veh_glow
			}	 
 	  
			action 
			{  
				close			all ; 
				exec			"helpusobi 1"
				exec			"npc spawn vehicle atst_vehicle"
			}
		}

