//----------------------------------------------------------------------------------------------
// SABER TYPE BUTTONS (standard, dual, two handed)
//----------------------------------------------------------------------------------------------

		itemDef 
		{
			name				typebut_single
			group				sabers
			text				@MENUS_SINGLESABER
			type				ITEM_TYPE_BUTTON
			style				WINDOW_STYLE_EMPTY
			rect				150 159 150 20
			font				5
			textscale			0.14
			textalign			ITEM_ALIGN_LEFT
			textstyle			3
			textalignx			0
			textaligny			2
			forecolor			1 1 1 0.9
			visible				0
			
			action 
			{
				play				"sound/interface/choose_saber.wav"
				transition2 		saber -80 -182 710 710 20 10
				transition2 		saber2 -80 -182 710 710 20 10
				setcvar				ui_saber_type	"single"
				uiScript  			"saber_type"
				setcvar				ui_saber		"single_1"
				setcvar				ui_saber2		""
				//exec				"saber single_1"
				uiScript  			"saber_hilt"
				uiScript  			"saber_color"
				uiScript  			"saber2_hilt"
				uiScript  			"saber2_color"
				uiScript  			"updatefightingstylechoices"
				setcvar			"saberStyleDescriptions" "1"
			}
		}

		itemDef 
		{
			name				typebut_dual
			group				sabers
			text				@MENUS_DUALSABERS
			type				ITEM_TYPE_BUTTON
			style				WINDOW_STYLE_EMPTY
			rect				150 179 150 20
			font				5
			textscale			0.14
			textalign			ITEM_ALIGN_LEFT
			textstyle			3
			textalignx			0
			textaligny			2
			forecolor			1 1 1 0.9
			visible				0

			action 
			{
				play				"sound/interface/choose_saber.wav"
				setcvar				ui_saber_type	"dual"
				uiScript  			"saber_type"
				setcvar				ui_saber		"single_1"
				setcvar				ui_saber2		"single_1"
				uiScript  			"saber_hilt"
				uiScript  			"saber_color"
				uiScript  			"saber2_hilt"
				uiScript  			"saber2_color"
				uiScript  			"updatefightingstylechoices"
				transition2 		saber -80 -207 710 710 20 10
				transition2 		saber2 -80 -156 710 710 20 10
				setcvar			"saberStyleDescriptions" "3"
			}
		}

		itemDef 
		{
			name				typebut_staff
			group				sabers
			text				@MENUS_SABERSTAFF
			type				ITEM_TYPE_BUTTON
			style				WINDOW_STYLE_EMPTY
			rect				150 199 150 20
			font				5
			textscale			0.14
			textalign			ITEM_ALIGN_LEFT
			textstyle			3
			textalignx			0
			textaligny			2
			forecolor			1 1 1 0.9
			visible				0

			action 
			{
				play				"sound/interface/choose_saber.wav"
				setcvar				ui_saber_type	"staff"
				uiScript  			"saber_type"
				setcvar				ui_saber		"dual_1"
				setcvar				ui_saber2		""
				//exec				"saber dual_1"
				uiScript  			"saber_hilt"
				uiScript  			"saber_color"
				uiScript  			"saber2_hilt"
				uiScript  			"saber2_color"
				uiScript  			"updatefightingstylechoices"
				transition2 		saber -80 -182 710 710 20 10
				hide			sabermenu_saberstyleglow
				hide			new_fightingstyle_desc
				setcvar			"saberStyleDescriptions" "4"
			}
		}
//----------------------------------------------------------------------------------------------
// Hilts
//----------------------------------------------------------------------------------------------

		// Saber hilts list feeder
		itemDef 
		{
			name				singlesaberhiltslist
			group				none //hilts
			rect				33 69 570 260
			type				ITEM_TYPE_LISTBOX
			style				WINDOW_STYLE_FILLED
			elementwidth		120
			elementheight		16
			font				5
			textaligny			8 
			textscale			0.14
			bordercolor			0 0 .8 0
			forecolor			.7 .7 .7 1
			
			backcolor			0 0 .5 0
			outlinecolor		1 .682 0 0
			elementtype			LISTBOX_TEXT
			feeder				88 // Single saber hilts
			notselectable
			visible				0
			columns				1 	2 55 300		//#of col., x loc. of 1st column, 2 number doesn't seem to do anything, third is width of column
			
			action 
			{
				uiScript  		"md_assignsaber1"
				uiScript  		"saber_hilt"
			}
		}	

		// Saber2 hilts list feeder
