			style				WINDOW_STYLE_EMPTY
			rect				25 152 120 68
			textalign			ITEM_ALIGN_RIGHT
			font				5
			textscale			0.19
			textaligny			27
			textstyle			3
			textalignx			110
			backcolor			0 0 0 0
			forecolor			1 1 1 0.9
			visible				1

			mouseEnter 
			{ 
				show			sabermenu_saberglow
			}
			mouseExit 
			{ 
				hide			sabermenu_saberglow	
			}
			action 
			{
				play			"sound/interface/button1.wav"
				show			sabers
				show			sabermenu_panelsabertype
				
				hide			typebut
				show			typebuthide
				setfocus		typebuthide
			}
		}

