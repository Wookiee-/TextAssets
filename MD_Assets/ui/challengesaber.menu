		// Single Expand
		itemDef 
		{
			name				hiltbut_expandsingle
			group				hilts
			text				@MENUS_SINGLESABER
			type				ITEM_TYPE_BUTTON
			style				WINDOW_STYLE_EMPTY
			rect				150 327 100 20
			font				5
			textscale			0.14
			textalign			ITEM_ALIGN_LEFT
			textstyle			3
			textalignx			0
			textaligny			2
			forecolor			0.5 0.5 0.5 0.9
			visible				0	
			cvarTest			ui_saber_type
			hideCvar			{ "staff"; "dual" }
			
