				"AOTC" 	                2 
				"ROTS"  	            3
				"ANH"	                4
				"ESB"                   5 
				"ROTJ"                  6  
				"TFA"                   7
				"UNSTABLE"              8  
				"REBELS"				9
			}
			text				@MD_MENU_SABER_SABER_BLADE
			rect				350.5 159 120 20
	   		textalign			ITEM_ALIGN_RIGHT
			textalignx			70
			textaligny			2
			font 				5
			textscale 			0.14
			forecolor			1 1 1 0.9
			visible				0
		
