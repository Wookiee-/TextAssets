//----------------------------------------------------------------------------------------------
//
// SABER CREATION MENU - called from main menu at the the start of a new game, 
//     and also when player is allowed to upgrade the fighting style and choose a new saber
//
//----------------------------------------------------------------------------------------------
{
	menuDef 
	{
		name					"challengesaberMenu"
		fullScreen				1					// MENU_TRUE				
		rect					0 0 640 480				// Size and position of the menu
		visible					1					// Visible on open
		focusColor				1 1 1 1					// Focus color for text and items
		descX					320
		descY					58
		descScale				0.6
		descColor				1 1 1 0.9
		descAlignment			ITEM_ALIGN_CENTER
	
		onOpen
		{ 
			//setcvar				"playersave" "(NULL)"
			//setcvar				"tiers_complete" "(NULL)"
			//uiScript  			"resetsabercvardefaults"
			uiScript  			"getsabercvars"
			uiScript  			"updatefightingstylechoices"
			uiScript  			"saber_hilt"
			uiScript  			"saber_color"
			uiScript  			"saber2_hilt"
			uiScript  			"saber2_color"

			setcvar			"saberStyleDescriptions" "1"
			hide			sabers
			hide			hilts
			hide			crystal
			hide			sabercolors1
			hide			sabercolors2
			hide			rgbcolors1
			hide			rgbcolors2
			hide			glow
			hide			singlesaberhiltslist
			hide			singlesaberhiltslist2
			hide			staffsaberhiltslist
			hide			Closebutton
			hide			ClosebuttonDual
			hide			backgroundhilts
			show			newgame_begin
			show			sabermenubutton
			hide			sabermenubuttonhide
			show			new_fightingstyle_button
			show			models
			show			backbutton
			setitemcolor	dual_color forecolor 0.5 0.5 0.5 0.9
			setitemcolor	Single_color forecolor  0.5 0.5 0.5 0.9

			setitemrect 		saber -80 -182 710 710 
			setitemrect 		saber2 -80 -156 710 710
		}
									
		onESC 
		{ 
			exec			"soundstop"
			play			"sound/interface/esc.wav" 
			exec			"music music/mainMenu/main/md_menu"							
			close			all ; 
			uiScript 		"updatesabercvars"
			uiScript 		"updatefightingstyle"
			open			challengecharacterMenu
		}


		//----------------------------------------------------------------------------------------------
		//
		//	MENU BACKGROUND
		//
		//----------------------------------------------------------------------------------------------

		itemDef 
		{
			name				backgroundsaber
			group				none
			style				WINDOW_STYLE_SHADER
			rect				0 0 640 480
			background			"gfx/menus/sp/saber/sabermenubk"
			forecolor			1 1 1 1
			visible				1
			decoration
		}
		
		itemDef 
		{
			name				backgroundhilts
			group				none
			style				WINDOW_STYLE_SHADER
			rect				0 0 640 480
			background			"gfx/menus/sp/saber/ingamehiltpanel"
			forecolor			1 1 1 1
			visible				0
			decoration
		}
		
		itemDef 
		{
			name				creation_panel
			group				none
			style				WINDOW_STYLE_SHADER
			rect				150.5 26 342 30.25
			background			"gfx/menus/main/buttons/MDMenuPanelTopGlow"
			forecolor			1 1 1 1
			visible				1
			decoration
		}
		
		itemDef 
		{
			name				style_panel
			group				none
