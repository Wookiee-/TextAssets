//----------------------------------------------------------------------------------------------
// SABER MENU TITLE AND MODEL
//----------------------------------------------------------------------------------------------

		// CREATION title

		itemDef 
		{
			name				creation_title
			group				none
			style				WINDOW_STYLE_EMPTY
			rect				235 30 180 20
			text				@MD_MENU_SABER_LIGHTSABER_CREATION
			font				5
			textscale			0.19
			textaligny			0
			textalign			ITEM_ALIGN_CENTER
			textstyle			3
			textalignx			85
			forecolor			1 1 1 0.9
			visible				1
			decoration
		}

		// Saber Model

		itemDef
		{
			name				saber
			group				models
			type 				ITEM_TYPE_MODEL
			rect				-80 -182 710 710
			asset_model			"models/weapons2/saber_1/saber_1.glm"
			isSaber				1
			model_angle			180
			model_rotation		20
			model_g2mins		0 0 0
			model_g2maxs		22 22 22
			model_fovx			87
			model_fovy			87
			visible				1
			decoration
		}

		itemDef
		{
			name				saber2
			group				models
			type 				ITEM_TYPE_MODEL
			rect				-80 -182 710 710
			asset_model			"models/weapons2/saber_1/saber_1.glm"
			isSaber2			1
			model_angle			180
			model_rotation		20
			model_g2mins		0 0 0
			model_g2maxs		22 22 22
			model_fovx			87
			model_fovy			87
			visible				1
			cvarTest			ui_saber_type
			hideCvar			{ "single" "staff" }
			decoration
		}

//----------------------------------------------------------------------------------------------
//	SABER COMBAT STYLES
//----------------------------------------------------------------------------------------------
		
		itemDef 
		{
			name				new_fightingstyle_button
			group				none
			text				@MD_MENU_SABER_LIGHTSABER_STYLE	
			desctext			@MD_MENU_SABER_LIGHTSABER_STYLE_DESC
			type				ITEM_TYPE_MULTI
			style				WINDOW_STYLE_EMPTY
			rect				200 72 241 24
			font				5
			textscale			0.19
			textalign			ITEM_ALIGN_LEFT
			textstyle			3
			textalignx			26
			textaligny			1
			forecolor			1 1 1 0.9
			
			cvar				"saberStyleDescriptions"
			cvarStrList
			{
				@MD_MENU_SABER_FAST_STANCE			"0"
				@MD_MENU_SABER_MEDIUM_STANCE		"1"
				@MD_MENU_SABER_STRONG_STANCE		"2"
				@MD_MENU_SABER_DUAL_STANCE			"3"
				@MD_MENU_SABER_STAFF_STANCE			"4"
				@MD_MENU_SABER_DESANN_STANCE		"5"
				@MD_MENU_SABER_TAVION_STANCE		"6"
			}

			visible				1
			 
			mouseEnter 
			{ 
				show			sabermenu_saberstyleglow
				show			new_fightingstyle_desc
			}
			mouseExit 
			{ 
				hide			sabermenu_saberstyleglow
				hide			new_fightingstyle_desc
			}	  	  
			action 
			{
				play			"sound/interface/button1.wav" 
			}
		}
		
		itemDef 
		{
			name				new_fightingstyle_desc
			group				none
			type				ITEM_TYPE_TEXTSCROLL
			text				@MD_MENU_SABER_FAST_STYLE
			desctext			@MD_MENU_SABER_LIGHTSABER_STYLE_DESC
			style				WINDOW_STYLE_EMPTY
			rect				23 98 617 125
			font				5
			textscale			0.14
			textalign			ITEM_ALIGN_LEFT
			textstyle			1
			textalignx			0
			textaligny			0
			forecolor			1 1 1 0.9		
			cvartest			"saberStyleDescriptions"
			showcvar
			{
				"0"
			}
			lineHeight			14
			visible				0		 
			autowrapped
		}

