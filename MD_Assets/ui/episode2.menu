		itemDef 
		{
			name				challenge_begin1
			group				none
			style				WINDOW_STYLE_EMPTY
			type				ITEM_TYPE_BUTTON
			rect				57 211 240 28
			text				@MD_MENU_MAIN_TC
			textaligny			4
			font				5
			textscale			0.19
			textalign			ITEM_ALIGN_CENTER
			textstyle			3
			textalignx			119
			forecolor			1 1 1 0.9
			visible				1

			mouseEnter 
			{ 
				fadein			background_tc
				setitemrect		background_MDMenuPanelGoldMiddle	16.5 211 320 30.25
				show			background_MDMenuPanelGoldMiddle
