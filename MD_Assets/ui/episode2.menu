//-----------------------------------------------------------------------
//	CHARACTERSELECT MENU
//
//	Called only from main menu. Has the transition of fields from main menu 
//	to new game menu
//
//-----------------------------------------------------------------------
{
						   
	menuDef 
	{
		name					"episode2Menu"
		fullScreen				1						// MENU_TRUE				
		rect					0 0 640 480					// Size and position of the menu
		visible					1						// Visible on open
		focusColor				1 1 1 1						// Focus color for text and items
		descX					320
		descY					422
		descScale				1.2
		descColor				1 .682 0 1
		descAlignment			ITEM_ALIGN_CENTER		

		fadeClamp				1.0					// sets the fadeup alpha
		fadeCycle				25					// how often fade happens in milliseconds
		fadeAmount				0.1				// amount to adjust alpha per cycle	


		onOpen
		{ 
				play			"sound/interface/transition.wav" 
				setcvar			g_spskill 1
				setcvar			cg_crosshairForceHint 1
				setcvar			handicap 100
				exec			"set ui_episode_credits ep2"
		}

		onESC 
		{
				exec			"soundstop"
				play			"sound/interface/esc.wav" 
				close			all ; 
				open			episodeMenu 
				exec			"music music/episodeMenu/EP2VideoMusic" ;
		}


		//----------------------------------------------------------------------------------------------
		//
		//	MENU BACKGROUND
		//
		//----------------------------------------------------------------------------------------------
		
		itemDef // Stop video in episode menu so video restarts and music is in sync
		{
			name				background_video_ROTE
			group				background
			style				WINDOW_STYLE_SHADER
			rect				0 0 128 90
			background			"gfx/menus/ROTEVideo"
			forecolor			1 1 1 1
			visible				1
			decoration
		}

		itemDef // Need solid background for fade 
		{
			name				black
			group				none
			style				WINDOW_STYLE_FILLED
			rect				0 0 640 480
			background			"gfx/menus/main/black"
			backcolor			1 1 1 1
			visible				1
			decoration
		}

		itemDef 
		{
			name				background_episode2
			group				none
			style				WINDOW_STYLE_FILLED
			rect				0 0 640 480
			background			"gfx/menus/mission/ep2/background_episode2"
			backcolor			1 1 1 1
			visible				1
			decoration
		}

		itemDef 
		{
			name				background_ail
			group				mods
			style				WINDOW_STYLE_FILLED
			background			"gfx/menus/mission/ep2/episode2_ail"
			backcolor			1 1 1 1
			visible				0
			decoration
		}

		itemDef 
		{
			name				background_ejf
			group				mods
			style				WINDOW_STYLE_FILLED
			background			"gfx/menus/mission/ep2/episode2_ejf"
			backcolor			1 1 1 1
			visible				0
			decoration
		}

		itemDef 
		{
			name				background_tc
			group				mods
			style				WINDOW_STYLE_FILLED
			background			"gfx/menus/mission/ep2/episode2_tc"
			backcolor			1 1 1 1
			visible				0
			decoration
		}

		itemDef 
		{
			name				background_ga
			group				mods
			style				WINDOW_STYLE_FILLED
			background			"gfx/menus/mission/ep2/episode2_ga"
			backcolor			1 1 1 1
			visible				0
			decoration
		}

		itemDef 
		{
			name				background_gb
			group				mods
			style				WINDOW_STYLE_FILLED
			background			"gfx/menus/mission/ep2/episode2_gb"
			backcolor			1 1 1 1
			visible				0
			decoration
		}

