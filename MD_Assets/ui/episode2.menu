			name				challenge_begin3
			group				none
			style				WINDOW_STYLE_EMPTY
			type				ITEM_TYPE_BUTTON
			rect				57 238 240 30
			text				@MD_MENU_MAIN_PA
			desctext			@MD_MENU_MAIN_MISSION_FPS_WARNING
			textaligny			5
			font				5
			textscale			0.19
			textalign			ITEM_ALIGN_CENTER
			textstyle			3
			textalignx			119
			forecolor			1 1 1 0.9
			visible				1

			mouseEnter 
			{ 
				fadein			background_ga
				setitemrect		background_MDMenuPanelGoldMiddle	16.5 239 320 30.25
