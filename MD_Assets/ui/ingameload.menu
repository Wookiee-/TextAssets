//----------------------------------------------------------------------------------------------
// INGAME MAIN MENU
//
//	Allows user to load from saved games. Called from in game main menu.
//----------------------------------------------------------------------------------------------
{
	menuDef 
	{
		// ***IMPORTANT*** This name can not change, code looks for it.
		// If it must change, change it in UI_AdjustSaveGameListBox() also
		//
		name					"ingameloadMenu"
		fullScreen				1							// MENU_TRUE				
		rect					0 0 640 480						// Size and position of the menu
		visible					1							// Visible on open
		focusColor				1 1 1 1						// Focus color for text and items
		descX					320
		descY					426
		descScale				1
		descColor				1 .682 0 0
		descAlignment				ITEM_ALIGN_CENTER		
		disablecolor			.7 .7 .7 1

		fadeClamp				1.0						// sets the fadeup alpha
		fadeCycle				50						// how often fade happens in milliseconds
		fadeAmount				50				// amount to adjust alpha per cycle

		onOpen 
		{
			uiScript			ReadSaveDirectory
			hide				background_MDIngameMenuPanelGold
			hide				background_MDMenuPanelGoldMiddle
		}

		onESC 
		{ 
				play			"sound/interface/esc.wav" 					
				close				all
				open				ingamemainmenu				
		}
												
//----------------------------------------------------------------------------------------------
//	MENU BACKGROUND
//----------------------------------------------------------------------------------------------
		itemDef //Stop white flash when video loads
		{
			name				background_black
			group				none
			style				WINDOW_STYLE_SHADER
			rect				0 0 640 480
			background			"gfx/menus/main/black"
			forecolor			1 1 1 1
			visible				1
			decoration
		}	

		itemDef 
		{
			name				background_mainvideo
