//----------------------------------------------------------------------------------------------
//   LOAD GAME MENU specific stuff
//----------------------------------------------------------------------------------------------

		itemDef 
		{
			// ***IMPORTANT*** This name can not change, code looks for it.
			// If it must change, change it in UI_AdjustSaveGameListBox() also
			//
			name				loadgamelist
			group				loadscreen
			rect				18 180 315 232
			type				ITEM_TYPE_LISTBOX
			style				WINDOW_STYLE_FILLED
			elementwidth			120
			elementheight			16
			font				5
			textaligny			8 
			textscale			0.16
			bordercolor			0 0 .8 0
			forecolor			.7 .7 .7 1
			
			
			backcolor			0 0 .5 0
			outlinecolor		1 .682 0 0
			elementtype			LISTBOX_TEXT
			feeder				FEEDER_SAVEGAMES
			notselectable
			visible				1
			columns				2 	2 55 140   145 0 175		//#of col., x loc. of 1st column, 2 number doesn't seem to do anything, third is width of column

			doubleclick
			{
				play			sound/interface/button1.wav
				uiScript		loadgame
			}
			action 
			{
				play			sound/interface/sub_select
			}
		}

		itemDef 
		{
			name				loadgamepic
			group				loadscreen
			style				WINDOW_STYLE_EMPTY	
			ownerdraw			236					//UI_ALLMAPS_SELECTION
			//font				5
			//textscale			0.19
			forecolor			1 1 1 1		
			rect				368 165 238 179
			border				1
			bordercolor			0 0 .8 0
			visible				1
			decoration
		}

		// loadgame button

		itemDef 
		{
			name				loadgameaction
			group				actionbutton
			text				@MENUS_LOAD_GAME
			descText			@MENUS_LOAD_CHOSEN_GAME
			type				ITEM_TYPE_BUTTON
			style				WINDOW_STYLE_EMPTY
			rect				369 348 240 24
			font				5
			textscale			0.19
			textalignx			119
			textaligny			2
			textalign			ITEM_ALIGN_CENTER
			textstyle			3
			forecolor			1 1 1 0.9
			visible				1
			cvarTest			ui_SelectionOK
			enableCvar			{ "1" }

			mouseEnter
			{
				setitemrect		background_MDMenuPanelGoldMiddle	327.7 346.4 320 30.75
				show			background_MDMenuPanelGoldMiddle
			}

			mouseExit
			{
				hide			background_MDMenuPanelGoldMiddle
			}
			action 
			{ 
				play			sound/interface/button1.wav ;
				hide			background_MDMenuPanelGoldMiddle
				uiScript		loadgame
			}
		}

		// deletegame button

		itemDef 
		{
			name				deletegamebutton
			group				actionbutton
			text				@MENUS_DELETE_GAME
			descText			@MENUS_DELETE_CHOSEN_GAME
			type				ITEM_TYPE_BUTTON
			style				WINDOW_STYLE_EMPTY
			rect				369 376 240 24 
			font				5
			textscale			0.19
			textalignx			119
			textaligny			2
			textalign			ITEM_ALIGN_CENTER
			textstyle			3
			forecolor			1 1 1 0.9
			visible				1
			cvarTest			ui_SelectionOK
			enableCvar			{ "1" }

			mouseEnter
			{
				setitemrect		background_MDMenuPanelGoldMiddle	327.7 374 320 30.75
				show			background_MDMenuPanelGoldMiddle
			}

			mouseExit
			{
				hide			background_MDMenuPanelGoldMiddle
			}
			action
			{ 
				play			sound/interface/button1.wav ;
				uiScript		deletegame
			}
		}

		
		// resumegame button

		itemDef 
		{
			name				resumeautobutton
			group				actionbutton
			text				@MENUS_RESUME_MISSION
			descText			@MENUS_RESUME_LAST_MISSION_ENTERED
			type				ITEM_TYPE_BUTTON
			style				WINDOW_STYLE_EMPTY
			rect				369 404 240 24
			font				5
			textscale			0.19
			textalignx			119
			textaligny			2
			textalign			ITEM_ALIGN_CENTER
			textstyle			3
			forecolor			1 1 1 0.9
			visible				1					// This button isn't used when not in game.
			cvarTest			ui_ResumeOK
			enableCvar			{ "1" }

			mouseEnter
			{
				setitemrect		background_MDMenuPanelGoldBottom	328.2 401.5 320 30.75
				show			background_MDMenuPanelGoldBottom
			}

			mouseExit
			{
				hide			background_MDMenuPanelGoldBottom
			}
			action
			{ 
				play			"sound/interface/button1.wav" ;
				hide			background_MDMenuPanelGoldBottom
				uiScript		loadAuto
			}
		}

		itemDef 
		{
			name				loadpanelbox
			group				none
			style				WINDOW_STYLE_SHADER
			rect				329 135 320 240
			background			"gfx/menus/main/loadpanelbox"
			forecolor			1 1 1 1
			visible				1
			decoration
		}

	}
}



















