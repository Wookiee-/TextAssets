		// Select Episode

		// TPM poster image small
		itemDef 
		{
			name				md_tpm_poster_small
			group				small_poster
			style				WINDOW_STYLE_SHADER
			type				ITEM_TYPE_BUTTON
			rect				0 347 49.2 90
			background			"gfx/menus/episode/md_tpm_poster_small"
			forecolor			1 1 1 0.6
			visible				1

			mouseEnter 
			{ 
				setitemcolor	md_tpm_poster_small forecolor 1 1 1 1
			}
			mouseExit 
			{ 
				setitemcolor	md_tpm_poster_small forecolor 1 1 1 0.6
			}
			action
			{
				setitemcolor	small_poster forecolor 1 1 1 0.6
				hide			background
				hide			small_poster
				hide			large_poster
				show			background_video_EP1
				exec			"soundstop"
				exec			"music music/episodeMenu/EP1VideoMusic"
				show			background_tpm
				show			md_tpm_poster
				show			small_poster
				setitemrect		md_aotc_poster_small 148 347 49.2 90
				setitemrect		md_cw_poster_small 197.2 347 49.2 90
				setitemrect		md_rots_poster_small 246.4 347 49.2 90
				setitemrect		md_rebels_poster_small 295.6 347 49.2 90
				setitemrect		md_anh_poster_small 344.8 347 49.2 90
				setitemrect		md_esb_poster_small 394 347 49.2 90
				setitemrect		md_rotj_poster_small 443.2 347 49.2 90
				setitemrect		md_tfa_poster_small 492.4 347 49.2 90
				setitemrect		md_tlj_poster_small 541.6 347 49.2 90
				setitemrect		md_tros_poster_small 590.8 347 49.2 90
				hide			md_tpm_poster_small
				setitemcolor	md_tpm_poster forecolor 1 1 1 1
				setfocus		md_tpm_poster

				//setitembackground	backgroundfadecurrent	"gfx/menus/episode/md_tpm_poster"
				setitemrect			backgroundfadecurrent	-6 -5 652 490
				setitemcolor		backgroundfadecurrent	backcolor 1 1 1 1
				show				backgroundfadecurrent
				fadeout				backgroundfadecurrent
			}
		}

		// TPM poster image button
		itemDef 
		{
			name				md_tpm_poster
			group				large_poster
			style				WINDOW_STYLE_SHADER
			type				ITEM_TYPE_BUTTON
			rect				0 347 148 90
			background			"gfx/menus/episode/md_tpm_poster"
			forecolor			1 1 1 1
			visible				0

			mouseEnter 
			{ 
				setitemcolor	md_tpm_poster forecolor 1 1 1 1
			}
			mouseExit 
			{ 
				setitemcolor	md_tpm_poster forecolor 1 1 1 0.6
			}	 
			action 
			{ 
				exec			"soundstop"
				exec			"music music/missionMenu/menu_ep1"
				play			"sound/interface/button1.wav" ; 
				setitemcolor	md_tpm_poster forecolor 1 1 1 0.6
				close			all ; 
				open			episode1menu
			}
		}

