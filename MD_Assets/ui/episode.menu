		//----------------------------------------------------------------------------------------------

		itemDef 
		{
			name				backbutton
			group				fade_buttons
			text				@MD_MENU_MAIN_BACK
			type				ITEM_TYPE_BUTTON
			style				WINDOW_STYLE_EMPTY
			rect				255 439 130 30  
			font				5
			textscale			0.19
			textalign			ITEM_ALIGN_CENTER
			textstyle			3
			textalignx			65
			textaligny			4
			forecolor			1 1 1 0.9
			visible				1

			action 
			{ 
				exec			"soundstop"
				play			"sound/interface/esc.wav" 
				exec			"menumusic"
				setitemcolor	small_poster forecolor 1 1 1 0.6
				hide			background
				hide			small_poster
				hide			large_poster
				show			background_video_EP4
				show			background_anh
				show			md_anh_poster
