//-----------------------------------------------------------------------
//	CHARACTERSELECT MENU
//
//	Called only from main menu. Has the transition of fields from main menu 
//	to new game menu
//
//-----------------------------------------------------------------------
{
						   
	menuDef 
	{
		name					"episodeMenu"
		fullScreen				1						// MENU_TRUE				
		rect					0 0 640 480					// Size and position of the menu
		visible					1						// Visible on open
		focusColor				1 1 1 1						// Focus color for text and items
		descX					320
		descY					426
		descScale				1
		descColor				1 .682 0 .8
		descAlignment				ITEM_ALIGN_CENTER		

		fadeClamp				1.0					// sets the fadeup alpha
		fadeCycle				25					// how often fade happens in milliseconds
		fadeAmount				0.05				// amount to adjust alpha per cycle	

		onOpen
		{
				setcvar			g_spskill 1
				setcvar			cg_crosshairForceHint 1
				setcvar			handicap 100

				setfocus			backbutton
				setitemcolor		backgroundfadecurrent backcolor 1 1 1 1
				show				backgroundfadecurrent
				fadeout				backgroundfadecurrent
		}				

		onESC 
		{ 
				exec			"soundstop"
				play			"sound/interface/esc.wav" 
				exec			"menumusic"
				setitemcolor	small_poster forecolor 1 1 1 0.6
				hide			background
				hide			small_poster
				hide			large_poster
				show			background_video_EP4
				show			background_anh
				show			md_anh_poster
				show			small_poster
				//setitembackground	backgroundfadecurrent	"gfx/menus/episode/md_anh_poster"
				setitemrect			backgroundfadecurrent	-6 -5 652 490
				setitemrect		md_tpm_poster_small 0 347 49.2 90
				setitemrect		md_aotc_poster_small 49.2 347 49.2 90
				setitemrect		md_cw_poster_small 98.4 347 49.2 90
				setitemrect		md_rots_poster_small 147.6 347 49.2 90
				setitemrect		md_rebels_poster_small 196.8 347 49.2 90
				setitemrect		md_esb_poster_small 394 347 49.2 90
				setitemrect		md_rotj_poster_small 443.2 347 49.2 90
				setitemrect		md_tfa_poster_small 492.4 347 49.2 90
				setitemrect		md_tlj_poster_small 541.6 347 49.2 90
				setitemrect		md_tros_poster_small 590.8 347 49.2 90
				hide			md_anh_poster_small
				close			all ; 
				open			mdnewgameMenu
		}

