		// Force powers

		itemDef
		{
			name				npcforceabsorb
			group				npcforcelight
			type				ITEM_TYPE_BUTTON
			rect				55 140 95 24
			text				@MD_MENU_MAIN_FORCE_ABSORB
			descText			@MD_MENU_MAIN_SET_FORCE_ABSORB_LEVEL
			font				5
			textscale			0.14
			textstyle			1
			forecolor			0 1 0 0.9
			textalignx			5
			textaligny			3
			visible			1
			action
			{
				hide			npcforcesub
				show			npcforceabsorbsub

				setitemcolor	force forecolor 1 1 1 0.9
				setitemcolor	npcforcelight forecolor 0 1 0 0.9
				setitemcolor	npcforcedark forecolor 1 0 0 0.9
				setitemcolor	npcforceneutral forecolor 1 1 0 0.9
				setitemcolor	npcforceabsorb forecolor 1 1 1 0.9
			}
		}

