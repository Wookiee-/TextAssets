//----------------------------------------------------------------------------------------------
// INGAME FORCE LOADOUT MENU
//
//	Allows user to customize their Force Power selection and levels.
//----------------------------------------------------------------------------------------------
{
	menuDef 
	{
		name					"ingameforceloadout"
		fullScreen				1		
		rect					0 0 640 480	
		visible					1
		focusColor				1 1 1 1
		descX					320
		descY					384
		descScale				0.82
		descColor				1 1 1 0.9
		descAlignment			ITEM_ALIGN_CENTER	
		descTextStyle			1	
		fadeClamp				1.0						// sets the fadeup alpha
		fadeCycle				25						// how often fade happens in milliseconds
		fadeAmount				0.05						// amount to adjust alpha per cycle	

		onOpen 
		{
 		}							
 		
		onESC 
		{ 
			play				"sound/interface/esc.wav"
			close				all
			open				ingameMainMenu
		}

