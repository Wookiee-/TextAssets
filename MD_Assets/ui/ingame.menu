//----------------------------------------------------------------------------------------------

		// Text "PAUSE MENU"
		itemDef 
		{
			name				PauseText
			group				pause
			style				WINDOW_STYLE_EMPTY
			type				ITEM_TYPE_TEXT
			rect				201 132 240 24
			text				@MD_MENU_MAIN_PAUSE_MENU
			font				5
			textscale			0.19
			textaligny			0
			textalign			ITEM_ALIGN_CENTER
			textstyle			3
			textalignx			119
			forecolor			1 1 1 0.9
			visible				1
			decoration
		}

		// Big button "CHARACTER"
		itemDef 
		{
			name				charactermenu
			group				pause
			style				WINDOW_STYLE_EMPTY
			type				ITEM_TYPE_BUTTON
			rect				201 160 240 24 
			text				@MD_MENU_MAIN_CHARACTER
			font				5
			textscale			0.19
			textaligny			0
			textalign			ITEM_ALIGN_CENTER
			textstyle			3
			textalignx			119
			forecolor			1 1 1 0.9
			visible				1
	  	  
			mouseEnter
			{
				setitemrect		background_MDMenuPanelGoldMiddle	160.5 156 320 30.25
				show			background_MDMenuPanelGoldMiddle
			}

			mouseExit
			{
				hide			background_MDMenuPanelGoldMiddle
			}
			action 
			{ 
				play			"sound/interface/button1.wav" ; 
				close			all ; 
				open			ingamecharacter
			}
		}
		
