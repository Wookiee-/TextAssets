		itemDef
		{
			name				CHARACTER_TITLE
			group				title
			type				ITEM_TYPE_TEXT
			text				@MD_MENU_MAIN_CHARACTER_MENU
			rect				30 37 100 26
			font				5
			textscale			0.19
			textalign			ITEM_ALIGN_LEFT
			textalignx			0
			textaligny			0
			textstyle			3
			forecolor			1 1 1 0.9
			visible				1
			decoration
		}

		itemDef
		{
			name				OLD_REPUBLIC_TITLE
			group				faction_titles
			type				ITEM_TYPE_TEXT
			text				@MD_MENU_MAIN_OLD_REPUBLIC
			rect				16 92 66 12
			font				5
			textscale			0.067
			textalign			ITEM_ALIGN_CENTER
			textalignx			33
			textaligny			0
			textstyle			3
			forecolor			1 0.78 0.388 1
			visible				1
			decoration
		}

		itemDef 
		{
			name				OLD_REPUBLIC_ICON
			group				faction_icons
			type				ITEM_TYPE_BUTTON
			style				WINDOW_STYLE_FILLED
			rect				36 68 26 26
			background			"gfx/menus/ingame/character/OR_icon"
			forecolor			1 1 1 1
			backcolor			1 1 1 1
			visible				0
  			
			mouseEnter
			{
				setitembackground	OLD_REPUBLIC_ICON	"gfx/menus/ingame/character/OR_icon_glow"
				setitemcolor		OLD_REPUBLIC_TITLE 	forecolor 1 0.78 0.388 1
			}
			mouseExit
			{
				setitembackground	OLD_REPUBLIC_ICON	"gfx/menus/ingame/character/OR_icon"
				setitemcolor		OLD_REPUBLIC_TITLE 	forecolor 1 1 1 0.9
			}
			action 
			{ 
				play				"sound/interface/button1.wav"  
				show				faction_icons
				hide				OLD_REPUBLIC_ICON
				setitembackground	OLD_REPUBLIC_ICON	"gfx/menus/ingame/character/OR_icon"
				show				SELECTED_FACTION_ICON
				setitemrect			SELECTED_FACTION_ICON	36 68 26 26
				setitembackground	SELECTED_FACTION_ICON	"gfx/menus/ingame/character/OR_icon_glow"
				setitemcolor		faction_titles			forecolor 1 1 1 0.9
				setitemcolor		OLD_REPUBLIC_TITLE 		forecolor 1 0.78 0.388 1
				uiScript			ERA_OLD_REPUBLIC
				uiScript			"characterchanged"
				uiScript			"md_char"
			}
		}

