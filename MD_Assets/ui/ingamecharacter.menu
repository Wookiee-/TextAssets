//----------------------------------------------------------------------------------------------
//
//	CHARACTER ERA MENU
//
//----------------------------------------------------------------------------------------------
{
	menuDef
	{
		name					"ingamecharacter"
		fullScreen				1									// MENU_TRUE
		rect					0 0 640 480							// Size and position of the menu
		focusColor				1 1 1 1				// Focus color for text and items
		descX					320
		descY					442
		descScale				0.7
		descColor				1 1 1 0.9
		descAlignment			ITEM_ALIGN_CENTER	
		descTextStyle			1
		visible					0								// Visible on open

		fadeClamp				1.0						// sets the fadeup alpha
		fadeCycle				10						// how often fade happens in milliseconds
		fadeAmount				0.1					// amount to adjust alpha per cycle

		onOpen
		{
			setfocus			resume ;
			uiScript			"md_char_init"
			uiScript			"characterchanged"
			uiScript			"md_char"
		}

		onESC
		{
			play				"sound/interface/esc.wav" 
			close				all
			open				ingameMainMenu
		}

		//----------------------------------------------------------------------------------------------
		//
		//	MENU BACKGROUND
		//
		//----------------------------------------------------------------------------------------------

		itemDef 
		{
			name				background
			group				none
			style				WINDOW_STYLE_FILLED
			rect				0 0 640 480
			background			"gfx/menus/ingame/character/background"
			backcolor			1 1 1 1
			visible				1
			decoration
		}

		// Character model
		itemDef
		{
			name				character
			group				models
			type 				ITEM_TYPE_MODEL
			rect				250 0 390 480
			model_g2anim		"BOTH_MENUIDLE1"
			asset_model			"ui_char_model"
			//asset_model		"models/players/jedi_hm/model.glm" //"ui_char_model"
			//model_g2skin		"models/players/jedi_hm/|head_b1|torso_f1|lower_a1"
			model_angle			180
			//mins maxs format is apparently z x y (hmmm... y x z?)
			model_g2mins		-30 -23 0
			model_g2maxs		20 7 44
			//model_rotation		50
			model_fovx			32
			model_fovy			32
			cvar				"ui_char_model_angle"
			isCharacter			1
			isSaber				1
	//		isSaber2			1
			visible				1
			decoration
		}

		itemDef
		{
			name				character_rotate
			descText			@MD_MENU_MAIN_CHARACTER_ROTATE
			group				models
			type 				ITEM_TYPE_SLIDER_ROTATE
			rect				400 0 240 340
			cvar				ui_char_model_angle
			isCharacter			1
			visible				1			
		}

		itemDef 
		{
			name				background
			group				none
			style				WINDOW_STYLE_SHADER
			rect				0 0 640 480
			background			"gfx/menus/ingame/character/background_overlay"
			forecolor			1 1 1 1
			visible				1
			decoration
		}

