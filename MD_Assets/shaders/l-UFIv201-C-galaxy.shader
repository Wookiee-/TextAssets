gfx/mp/f_icon_dk_drain
{
	nopicmip
	nomipmaps

	//Red fractal 1
    {
        clampmap gfx/mp/redfractal
        blendFunc GL_ONE GL_ONE
        glow
        rgbGen vertex
        tcMod rotate 100
	rgbGen wave sin 0.53 0. 34. 0.6 //0.5 0.35 0 0.6
    }
	//Red fractal 2
    {
        clampmap gfx/mp/redfractal2
        blendFunc GL_ONE GL_ONE
        glow
        rgbGen vertex
        tcMod rotate -100
	rgbGen wave sin 0.53 0. 34. 0.6 //0.5 0.35 0 0.6
    }
	//Red fractal 2
    {
        clampmap gfx/mp/redfractal2
        blendFunc GL_ONE GL_ONE
        glow
        rgbGen vertex
        tcMod rotate 100
	rgbGen wave sin 0.53 0. 34. 0.6 //0.5 0.35 0 0.6
    }

    {
        map gfx/mp/f_icon_dk_drain
        alphaFunc GT0
        blendFunc GL_SRC_ALPHA GL_ONE
        glow
        rgbGen identity
    }
	//Red glitter shader - spinning glitter
   {
        clampmap gfx/mp/redglitter
        blendFunc GL_ONE GL_ONE
        glow
        rgbGen vertex
        tcMod rotate 50//100
	tcMod turb 0 0.02 0 .8
	rgbGen wave sin 0 1 1 .7 //.6
    }
	//Red glitter 2 shader - spinning glitter
   {
        clampmap gfx/mp/redglitter2
        blendFunc GL_ONE GL_ONE
        glow
        rgbGen vertex
        tcMod rotate -50
	tcMod turb 0 0.02 0 .65 
	rgbGen wave sin 0 1 1 .36
    }

	
}

