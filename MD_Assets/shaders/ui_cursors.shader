     // seta g_cursor 0 = base jka cursor

gfx/menus/cursor_anakin  //g_cursor 1
{
	nopicmip
	nomipmaps
    {
        clampmap gfx/menus/cursor_anakin1
        blendFunc GL_SRC_ALPHA GL_ONE_MINUS_SRC_ALPHA
        rgbGen identity
    }
    {
        clampmap gfx/menus/cursor_anakin2
        blendFunc GL_ONE GL_ONE
        rgbGen wave random 0.5 0.25 0.25 1
        tcMod stretch noise 1 0.02 0 10
    }
    {
        clampmap gfx/menus/cursor_anakin3
        blendFunc GL_ONE GL_ONE
        rgbGen wave random 0.5 0.1 0 1
    }
}

