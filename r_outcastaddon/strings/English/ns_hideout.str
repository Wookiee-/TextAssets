LANG_ENGLISH        "Reelo"

REFERENCE           10KJO023
LANG_ENGLISH        "Garbage"

REFERENCE           10KJO024
LANG_ENGLISH        "Desann"

REFERENCE           10KJO025
LANG_ENGLISH        "I don't know"

