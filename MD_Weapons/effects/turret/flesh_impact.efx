// Dark smoke
Particle
{
	count	7	8
	life	1200	1700

	origin	2 -3 -3		2 3 3
	vel	15 -12 -12		20 12 12
	gravity	12	24

	flags	useAlpha

	size
	{
		start 	2.0	6.0
		end	6.0	10.0
		flags	linear
	}

	alpha
	{
		start	1.0
		end 	0.0
		parm	60 	75
		flags	nonlinear
	}

	shader
	[
		gfx/misc/black_smoke
	]
}
