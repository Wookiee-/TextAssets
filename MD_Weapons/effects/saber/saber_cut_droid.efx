// Advanced MD Mode Effect

repeatDelay				300

Sound
{
	sounds
	[
		sound/weapons/saber/saberhit_droid_md1.mp3
            sound/weapons/saber/saberhit_droid_md2.mp3
            sound/weapons/saber/saberhit_droid_md3.mp3
            sound/weapons/saber/saberhit_droid_md4.mp3
            sound/weapons/saber/saberhit_droid_md5.mp3
	]
}

Line
{
	count				2 5

	life				100

	origin2				2 -10 -10 1 10 10

	rgb
	{
		start			0.9961 0.9608 0.7294 1 1 1
	}

	alpha
	{
		start			0.25 1
		end				0
		flags			linear
	}

	size
	{
		start			0.2 0.5
	}

	shaders
	[
		gfx/misc/sparkblue
	]
}

Tail
{
	spawnFlags			evenDistribution

	count				5 25

	life				1000 1500

	delay				100 0

	velocity			200 -80 -80 -50 80 80

	gravity				-350 -450

