	{
		start			0.9961 0.9608 0.7294 1 0.7922 0.3569
	}

	alpha
	{
		end				0
		flags			linear
	}

	size
	{
		start			1 2
	}

	length
	{
		start			3 5
		end				0.1 0.5
		flags			linear
	}

	shaders
	[
		gfx/misc/sparkblue
	]
}

